    <!-- https://purl.org/eudpp#Concentration -->

    <owl:Class rdf:about="https://purl.org/eudpp#Concentration">
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <dcterms:references xml:lang="en">ESPR Art 7(5)</dcterms:references>
        <rdfs:comment xml:lang="en">The concentration of the substances of concern, at the level of the product, its relevant components, or spare parts ESPR Art 7(5)</rdfs:comment>
        <rdfs:label xml:lang="en">Concentration of the substance of concern</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#Substance -->

    <owl:Class rdf:about="https://purl.org/eudpp#Substance">
        <dcterms:source>http://data.europa.eu/eli/reg/2006/1907/oj</dcterms:source>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <dcterms:references xml:lang="en">ESPR Art 2</dcterms:references>
        <dcterms:references xml:lang="en">Regulation (EC) No 1907/2006</dcterms:references>
        <rdfs:comment xml:lang="en">Means a chemical element and its compounds in the natural state or obtained by any manufacturing process, including any additive necessary to preserve its stability and any impurity deriving from the process used, but excluding any solvent which may be separated without affecting the stability of the substance or changing its composition; ESPR Art 2, Regulation (EC) No 1907/2006</rdfs:comment>
        <rdfs:label xml:lang="en">Substance</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#SubstanceOfConcern -->

    <owl:Class rdf:about="https://purl.org/eudpp#SubstanceOfConcern">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Substance"/>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <dcterms:references xml:lang="en">ESPR Art 2(10)</dcterms:references>
        <rdfs:comment xml:lang="en">means a substance that:(a) meets the criteria laid down in Article 57 of Regulation (EC) No 1907/2006 and is identified in accordance with Article 59(1) of that Regulation; (b) is classified in Part 3 of Annex VI to Regulation (EC) No 1272/2008 in one of the following hazard classes or hazard categories: (i) carcinogenicity categories 1 and 2; (ii) germ cell mutagenicity categories 1 and 2; (iii) reproductive toxicity categories 1 and 2; (iv) endocrine disruption for human health categories 1 and 2; (v) endocrine disruption for the environment categories 1 and 2; (vi) persistent, mobile and toxic or very persistent, very mobile properties; (vii) persistent, bioaccumulative and toxic or very persistent, very bioaccumulative properties; (viii) respiratory sensitisation category 1; (ix) skin sensitisation category 1; (x) hazardous to the aquatic environment — categories chronic 1 to 4; (xi) hazardous to the ozone layer; (xii) specific target organ toxicity — repeated exposure categories 1 and 2; (xiii) specific target organ toxicity — single exposure categories 1 and 2; (c) is regulated under Regulation (EU) 2019/1021; or (d) negatively affects the reuse and recycling of materials in the product in which it is present [ESPR Art 2(10)]</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://purl.org/eudpp/SOC"/>
        <rdfs:label xml:lang="en">Substance of concern</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#Threshold -->

    <owl:Class rdf:about="https://purl.org/eudpp#Threshold">
        <dcterms:source>https://circabc.europa.eu/ui/group/418195ae-4919-45fa-a959-3b695c9aab28/library/25c48e7c-9ce3-41cb-96ac-d2942a8a29d6/details</dcterms:source>
        <dcterms:references xml:lang="en">ESPR FAQ 10.115, p59</dcterms:references>
        <rdfs:comment xml:lang="en">Relevant threshold of Substance of Concern.

By default, information on all substances of concern present in a product, above the  relevant thresholds, should be included in the DPP [ESPR FAQ 10.115, p59]</rdfs:comment>
        <rdfs:label xml:lang="en">Threshold of substance of concern</rdfs:label>
    </owl:Class>
</rdf:RDF>



