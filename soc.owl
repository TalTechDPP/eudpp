        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <dcterms:references xml:lang="en">ESPR Article 7(5)</dcterms:references>
        <rdfs:comment xml:lang="en">The Chemical Abstract Service (CAS) name, if available; [ESPR Article 7(5)]</rdfs:comment>
