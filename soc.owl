        <rdfs:comment xml:lang="en">Third iteration of the Substances of Concern module of the EU DPP core ontology proposal of the CIRPASS-2 European project.</rdfs:comment>
        <rdfs:label xml:lang="en">EU DPP SOC</rdfs:label>
        <owl:versionInfo>1.9.1</owl:versionInfo>
    </owl:Ontology>
    


