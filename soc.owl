        <rdfs:comment xml:lang="en">Describes the impacts of Substance of Concern on human health; ESPR Annex I (f)</rdfs:comment>
        <rdfs:label xml:lang="en">Has impact on human health</rdfs:label>
    </owl:DatatypeProperty>
    


