        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <dcterms:references xml:lang="en">ESPR Article 7(5)</dcterms:references>
        <rdfs:comment xml:lang="en">Location of the substance in the product; ESPR Art 7(5)</rdfs:comment>
        <rdfs:label xml:lang="en">Location of substance</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#tradeName -->

