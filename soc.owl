        <rdfs:comment xml:lang="en">Describes the impacts of Substance of Concern on environment; ESPR Annex I (f)</rdfs:comment>
        <rdfs:label xml:lang="en">Has impact on environment</rdfs:label>
    </owl:DatatypeProperty>
    


