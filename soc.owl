    <!-- https://purl.org/eudpp#hasConcentration -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasConcentration">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#SubstanceOfConcern"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Concentration"/>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <dcterms:references xml:lang="en">ESPR Art 7(5)</dcterms:references>
        <rdfs:comment xml:lang="en">Defines the the concentration, maximum concentration or concentration range of the substances of concern, at the level of the product, its relevant components, or spare parts; ESPR Art 7(5)</rdfs:comment>
        <rdfs:label xml:lang="en">Has concentration</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasLifeCycleStage -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasLifeCycleStage">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#SubstanceOfConcern"/>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <dcterms:references xml:lang="en">ESPR Annex I (f)</dcterms:references>
        <rdfs:comment xml:lang="en">Describes the life cycle stage during which the Substance of Concern occurs for product (used during production, resulting being in product, in waste); ESPR Annex I (f).

Known issue: Range is some type of an Event, not yet present in the EU DPP CO.</rdfs:comment>
        <rdfs:label xml:lang="en">Has life cycle stage</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasThreshold -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasThreshold">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#SubstanceOfConcern"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Threshold"/>
        <dcterms:source>https://circabc.europa.eu/ui/group/418195ae-4919-45fa-a959-3b695c9aab28/library/25c48e7c-9ce3-41cb-96ac-d2942a8a29d6/details</dcterms:source>
        <dcterms:references xml:lang="en">ESPR FAQ 10.115, p59</dcterms:references>
        <rdfs:comment xml:lang="en">Describes relevant threshold of Substance of Concern.

By default, information on all substances of concern present in a product, above the  relevant thresholds, should be included in the DPP [ESPR FAQ 10.115, p59]</rdfs:comment>
        <rdfs:label xml:lang="en">Has threshold</rdfs:label>
    </owl:ObjectProperty>
    


