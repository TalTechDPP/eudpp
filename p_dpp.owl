    <!-- https://purl.org/eudpp#Reliability -->

    <owl:Class rdf:about="https://purl.org/eudpp#Reliability">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#QualityIndicator"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (16)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Reliability
means the probability that a product functions as required under given conditions for a given
duration without an occurrence which results in a primary or secondary function of the product no
longer being performed. (ESPR Art 2 (16))

Reliability is usually expressed in terms of mean time between failures (MTBF), which is the average length of time that a device will operate without failure.

This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">Reliability</rdfs:label>
    </owl:Class>
    


