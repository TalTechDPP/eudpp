<?xml version="1.0"?>
<rdf:RDF xmlns="https://purl.org/eudpp"
     xml:base="https://purl.org/eudpp"
     xmlns:si="https://si-digital-framework.org/SI#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:eudpp="https://purl.org/eudpp"
     xmlns:schema="http://schema.org/"
     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://purl.org/eudpp/P_DPP">
        <dcterms:bibliographicCitation rdf:resource="https://doi.org/10.5281/zenodo.15270342"/>
        <dcterms:contributor xml:lang="en">Riina Maigre</dcterms:contributor>
        <dcterms:contributor xml:lang="en">Tarmo Robal</dcterms:contributor>
        <dcterms:contributor xml:lang="en">Theodor Chirvasuta</dcterms:contributor>
        <dcterms:created>2025-01-29</dcterms:created>
        <dcterms:creator xml:lang="en">Hele-Mai Haav (up until version 1.7.1 incl.), further maintained by contributors.</dcterms:creator>
        <dcterms:description xml:lang="en">The EU DPP core ontology proposed in CIRPASS-2 European project  is a shared formal specification of basic concepts and properties/relationships in the cross-sectorial DPP domain to facilitate knowledge sharing across sector-specific DPPs.

The proposed  EU DPP core ontology captures several modules from which the Product and DPP module plays a central role.

DEPENDENCIES:  This module has dependencies to the following EU DPP Core Ontology (CO) modules: CON, ACTOR, SOC.  

For more information, see 
Maigre, R., Haav, H.-M., Robal, T., Wolf, M.-A., &amp; Danash, F. (2025). Ontology Requirements Specification for an EU DPP Core Ontology Proposal (1.1). CIRPASS-2 Consortium. https://doi.org/10.5281/zenodo.15270342

=======================

CHANGES APR 2026 (JTC24 alignment) (v.1.9.2)
1. Added additional values for range: Inactive, Invalid for data property DPP status
2. Rename #status to #dppStatus, change of IRI.
3. Rename #uniqueDPPID to #digitalProductPassportId, change of IRI, label and range.
4. Rename #schemaVersion to #dppSchemaVersion, change of IRI, label.
5. Changing data property #granularity range to model, batch or item (refactoring product to item). 

CHANGES FEB 2026 (v.1.9.1)
1. Alignment with design principles
2. skos:exactMatch for Product changed to more appropriate skos:closeMatch
3. Renamed uniqueProductID to uniqueProductIdentifier
4. Added uniqueProductIdentifierScheme
5. Removed #facilityID. Now described through ACTOR module.
6. #Document renamed to #DocumentFormattedProperty
7. The following object properties were removed and added to connector:
 #containsSubstanceOfConcern
 #hasEconomicOperator
 #hasBackUpCopyHost
 #hasIssuer 
 #hasManufacturer</dcterms:description>
        <dcterms:issued>2026-04-21</dcterms:issued>
        <dcterms:license rdf:resource="https://www.apache.org/licenses/LICENSE-2.0"/>
        <dcterms:license xml:lang="en">This ontology is licensed under the Apache License, Version 2.0. 
In case of dispute over Apache 2.0 applicability, or in case considering the ontology as a document, this ontology document is to be considered licensed under the Creative Commons Attribution 4.0 International (CC BY 4.0).</dcterms:license>
        <dcterms:title xml:lang="en">The Product and DPP module of an EU regulatory compliant Digital Product Passport Core Ontology (EU DPP CO) proposed by the CIRPASS-2 European project.</dcterms:title>
        <vann:preferredNamespacePrefix>dpp</vann:preferredNamespacePrefix>
        <rdfs:comment xml:lang="en">The Product and DPP module of an EU DPP core ontology proposed by the CIRPASS-2 European project.</rdfs:comment>
        <rdfs:label xml:lang="en">EU DPP CO P_DPP</rdfs:label>
        <owl:versionInfo>1.9.2</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/terms/bibliographicCitation -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/bibliographicCitation"/>
    


    <!-- http://purl.org/dc/terms/contributor -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/contributor"/>
    


    <!-- http://purl.org/dc/terms/created -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/created"/>
    


    <!-- http://purl.org/dc/terms/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/identifier -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/identifier"/>
    


    <!-- http://purl.org/dc/terms/issued -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/issued"/>
    


    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/modified -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/modified"/>
    


    <!-- http://purl.org/dc/terms/references -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/references"/>
    


    <!-- http://purl.org/dc/terms/source -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/source"/>
    


    <!-- http://purl.org/dc/terms/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->

    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#closeMatch -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#closeMatch"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#exactMatch -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#exactMatch"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://purl.org/eudpp#appliesToProduct -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#appliesToProduct">
        <owl:inverseOf rdf:resource="https://purl.org/eudpp#hasDPP"/>
        <rdfs:domain rdf:resource="https://purl.org/eudpp#DPP"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:comment xml:lang="en">The property links DPP and the Product.</rdfs:comment>
        <rdfs:label xml:lang="en">Applies to product</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasDPP -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasDPP">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#DPP"/>
        <rdfs:comment xml:lang="en">A Product has a DPP. The property links a Product with a DPP.</rdfs:comment>
        <rdfs:label xml:lang="en">Has DPP</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasMeasurementUnit -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasMeasurementUnit">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#QuantitativeProperty"/>
        <rdfs:range rdf:resource="https://si-digital-framework.org/SI#MeasurementUnit"/>
        <rdfs:comment xml:lang="en">Linking quantitative property to the unit of measurement.</rdfs:comment>
        <rdfs:label xml:lang="en">Has measurement unit</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasProductGroup -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasProductGroup">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#ClassificationCode"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (4)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Product group
means a set of products that serve similar purposes and are similar in terms of use, or have similar
functional properties, and are similar in terms of consumer perception (ESPR Art 2 (4)). The product
group or groups covered are given by delegated acts. (ESPR Art 8 (a))

This will be probably a classification code from some product classification scheme .</rdfs:comment>
        <rdfs:label xml:lang="en">Has Product group</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasProperty -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasProperty">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Property"/>
        <rdfs:comment xml:lang="en">Product has a property that could be a document or some measurable properties (measurands).

Linking the product to the property.</rdfs:comment>
        <rdfs:label xml:lang="en">Has property</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#isComponentOf -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#isComponentOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Product"/>
        <dcterms:references xml:lang="en">ESPR Art 2(2)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">A product is a component of another product.

‘component’ means a product intended to be incorporated into another product; [ESPR Art 2(2)]</rdfs:comment>
        <rdfs:label xml:lang="en">Is component of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#isSparePartOf -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#isSparePartOf">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Product"/>
        <dcterms:references xml:lang="en">ESPR Annex I</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">A product is a spare part of another product.</rdfs:comment>
        <rdfs:label xml:lang="en">Is spare part of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://purl.org/eudpp#GTIN -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#GTIN">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dcterms:references xml:lang="en">ESPR Annex III (c)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Global Trade Identification Number as provided for in standard ISO/IEC 15459-6 or equivalent of products or their parts.</rdfs:comment>
        <rdfs:label xml:lang="en">GTIN</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#codeSet -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#codeSet">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#ClassificationCode"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">The product classification code set.

See also Produc hasProductGroup ClassificationCode documentation.</rdfs:comment>
        <rdfs:label xml:lang="en">Classification code set</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#codeValue -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#codeValue">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#ClassificationCode"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Classification code value from the Classification code set.</rdfs:comment>
        <rdfs:label xml:lang="en">Classification code value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#commodityCode -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#commodityCode">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dcterms:references xml:lang="en">ESPR Annex III (d)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Relevant commodity codes, such as a TARIC code as defined in Council Regulation (EEC) No 2658/87.[ESPR Annex III (d)]</rdfs:comment>
        <rdfs:label xml:lang="en">Commodity code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#contentType -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#contentType">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#DocumentFormattedProperty"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>application</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>pdf</rdf:first>
                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Content type of a document. Can be only “application” or “pdf”.</rdfs:comment>
        <rdfs:label xml:lang="en">Content type</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#description -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#description">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Product description</rdfs:comment>
        <rdfs:label xml:lang="en">Description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#dictionaryReference -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#dictionaryReference">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Property"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The reference to the unique identifier of the data point specification defined in the repository/data dictionary.

It is formatted as a URI/URL .</rdfs:comment>
        <rdfs:label xml:lang="en">Dictionary reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#digitalProductPassportId -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#digitalProductPassportId">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#DPP"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Unique identifier of an instance of the digital product passport</rdfs:comment>
        <rdfs:label xml:lang="en">Digital Product Passport Id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#dppSchemaVersion -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#dppSchemaVersion">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#DPP"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The reference standard the DPP instance schema refers to.</rdfs:comment>
        <rdfs:label xml:lang="en">DPP schema version</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#dppStatus -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#dppStatus">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#DPP"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>Active</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>Archived</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>Inactive</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>Invalid</rdf:first>
                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment xml:lang="en">The status of the DPP instance as digital resource.</rdfs:comment>
        <rdfs:label xml:lang="en">DPP status</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#granularity -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#granularity">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#DPP"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first> batch</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>item</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>model</rdf:first>
                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <dcterms:references xml:lang="en">ESPR Art 9 (2) d</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">The product passport should be defined at the level of item, batch or product model, depending on specific needs and complexity of the value chain, the size, nature or impacts of the products considered. (Standardisation Request 5423 7)

The level of granularity of the ProductID as per ESPR.</rdfs:comment>
        <rdfs:label xml:lang="en">Granularity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#isEnergyRelated -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#isEnergyRelated">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (4)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Energy related product
means any product that has an impact on energy consumption during use. (ESPR Art 2 (4)).

The boolean data type property indicates is a Product energy related or not?</rdfs:comment>
        <rdfs:label xml:lang="en">Is energy related Product</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#lastUpdate -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#lastUpdate">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#DPP"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTimeStamp"/>
        <rdfs:comment xml:lang="en">The date and time of the latest update to the DPP instance.</rdfs:comment>
        <rdfs:label xml:lang="en">Last update</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#linkToPreviousDPP -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#linkToPreviousDPP">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#DPP"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <dcterms:references xml:lang="en">ESPR Art 11 (d)</dcterms:references>
        <dcterms:references>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:references>
        <rdfs:comment xml:lang="en">Where a new digital product passport is created for a product that already has a digital product passport, the new digital product passport shall be linked to the original digital product passport or passports. (ESPR Art 11 (d))</rdfs:comment>
        <rdfs:label xml:lang="en">Link to previous DPP</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#numericalValue -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#numericalValue">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#QuantitativeProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">The numerical value of the quantity, i.e., quantitative property of the product.</rdfs:comment>
        <rdfs:label xml:lang="en">Numerical value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#productImage -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#productImage">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">An image of the product.</rdfs:comment>
        <rdfs:label xml:lang="en">Product image</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#productName -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#productName">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Product name</rdfs:comment>
        <rdfs:label xml:lang="en">Product name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#tolerance -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#tolerance">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#QuantitativeProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Engineering tolerance is the permissible variation in measurements deriving from the base measurement.
Tolerances can apply to many different units.</rdfs:comment>
        <rdfs:label xml:lang="en">Tolerance</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#uniqueProductIdentifier -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#uniqueProductIdentifier">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#anyURI"/>
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#string"/>
                </owl:unionOf>
            </rdfs:Datatype>
        </rdfs:range>
        <dcterms:references xml:lang="en">ESPR Art 2 (30)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Unique product identifier
means a unique string of characters for the identification of a product that also enables a web link to the digital product passport. (ESPR Art 2 (30))</rdfs:comment>
        <rdfs:label xml:lang="en">Unique product identifier</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#validFrom -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#validFrom">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#DPP"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTimeStamp"/>
        <rdfs:comment xml:lang="en">The date and timestamp that the DPP is valid from.</rdfs:comment>
        <rdfs:label xml:lang="en">Valid from</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#validUntil -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#validUntil">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#DPP"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTimeStamp"/>
        <rdfs:comment xml:lang="en">The date and timestamp that the DPP is valid until.</rdfs:comment>
        <rdfs:label xml:lang="en">Valid until</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#value -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#value">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#DocumentFormattedProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Contains the data of the value encapsulated in the Document.

Value is xsd:string that is formatted as a URL,  where to fetch the file.</rdfs:comment>
        <rdfs:label xml:lang="en">Value related to the document</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#webLink -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#webLink">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#DigitalInstruction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">Web link to an instruction document or video etc.</rdfs:comment>
        <rdfs:label xml:lang="en">Weblink</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/eudpp#uniqueProductIdentifierScheme -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/eudpp#uniqueProductIdentifierScheme">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The coding scheme used for the uniqueProductIdentifier. 
Specific scheme specified by ESPR delegated acts, or similar, for sectorial usage</rdfs:comment>
        <rdfs:label xml:lang="en">Unique product identifier scheme</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://purl.org/eudpp#CarbonFootprint -->

    <owl:Class rdf:about="https://purl.org/eudpp#CarbonFootprint">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#EnvironmentalFootprint"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (25)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Carbon footprint
means the sum of greenhouse gas emissions and greenhouse gas removals in a product system, expressed as CO equivalents and based on a life cycle assessment using the single impact category
of climate change. (ESPR Art 2 25))

This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">Carbon footprint</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#CircularEconomyIndicator -->

    <owl:Class rdf:about="https://purl.org/eudpp#CircularEconomyIndicator">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#QuantitativeProperty"/>
        <rdfs:comment xml:lang="en">Circular Economy indicators are measures for relevant monitoring the transition to a circular economy and to measure the effects of new policy and trends.

This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">Circular Economy Indicator</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://environment.ec.europa.eu/strategy/circular-economy-action-plan_en"/>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#ClassificationCode -->

    <owl:Class rdf:about="https://purl.org/eudpp#ClassificationCode">
        <rdfs:comment xml:lang="en">A classification code from some product classification scheme .</rdfs:comment>
        <rdfs:label xml:lang="en">ClassificationCode</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#ConcentrationOfSubstanceOfConcern -->

    <owl:Class rdf:about="https://purl.org/eudpp#ConcentrationOfSubstanceOfConcern">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#QuantitativeProperty"/>
        <dcterms:references xml:lang="en">ESPR Art 7(5)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">The concentration of the substances of concern, at the level of the product, its relevant components, or spare parts ESPR Art 7(5)</rdfs:comment>
        <rdfs:label xml:lang="en">Concentration of the substance of concern</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#DPP -->

    <owl:Class rdf:about="https://purl.org/eudpp#DPP">
        <dcterms:references xml:lang="en">ESPR Art 2 (28)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Digital Product Passport (DPP) means a set of data specific to a product that includes the information specified in the applicable
delegated act adopted pursuant to Article 4 and that is accessible via electronic means through a data carrier in accordance with Chapter III. (ESPR Art 2 (28))</rdfs:comment>
        <rdfs:label xml:lang="en">Digital Product Passport (DPP)</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#DigitalInstruction -->

    <owl:Class rdf:about="https://purl.org/eudpp#DigitalInstruction">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#DocumentFormattedProperty"/>
        <dcterms:references xml:lang="en">ESPR Art 27(7)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Digital instructions
mean instructions in digital format concerning the product (‘digital instructions’) in a language that can be easily understood. ESPR Art 27(7)
Digital instructions are ensured by manufacturers. These should also ensured by importers. (ESPR Art 29(4))

This class can be extended/specialised according to delegated acts or industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">DigitalInstruction</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#DocumentFormattedProperty -->

    <owl:Class rdf:about="https://purl.org/eudpp#DocumentFormattedProperty">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Property"/>
        <rdfs:comment xml:lang="en">The document class describes the semantic representation of any instance of a document that might be required to be included into a digital product passport instance.</rdfs:comment>
        <rdfs:label xml:lang="en">Document</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#Durability -->

    <owl:Class rdf:about="https://purl.org/eudpp#Durability">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#QualityIndicator"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (22)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Durability
means the ability of a product to maintain over time its function and performance under specified conditions of use, maintenance and repair. (ESPR Art 2 (22))

This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">Durability</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#EmissionToAir -->

    <owl:Class rdf:about="https://purl.org/eudpp#EmissionToAir">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#EnvironmentalEmission"/>
        <dcterms:references xml:lang="en">ESPR Annex I</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Product parameters are listed in the ESPR Annex I :

(q) emissions to air, water or soil released in one or more lifecycle stages of the product as expressed through quantities and nature of emissions, including noise.

This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">Emission to air</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#EmissionToSoil -->

    <owl:Class rdf:about="https://purl.org/eudpp#EmissionToSoil">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#EnvironmentalEmission"/>
        <dcterms:references xml:lang="en">ESPR Annex I</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Product parameters are listed in the ESPR Annex I :

(q) emissions to air, water or soil released in one or more lifecycle stages of the product as expressed through quantities and nature of emissions, including noise.

This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">Emission to soil</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#EmissionToWater -->

    <owl:Class rdf:about="https://purl.org/eudpp#EmissionToWater">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#EnvironmentalEmission"/>
        <dcterms:references xml:lang="en">ESPR Annex I</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Product parameters are listed in the ESPR Annex I :

(q) emissions to air, water or soil released in one or more lifecycle stages of the product as expressed through quantities and nature of emissions, including noise.

This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">Emission to water</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#EnergyConsumption -->

    <owl:Class rdf:about="https://purl.org/eudpp#EnergyConsumption">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#ResourceConsumption"/>
        <rdfs:comment xml:lang="en">Energy consumption of the product.

This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">Energy consumption</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#EnvironmentalEmission -->

    <owl:Class rdf:about="https://purl.org/eudpp#EnvironmentalEmission">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#EnvironmentalPollution"/>
        <rdfs:comment xml:lang="en">Emission is the act or amount of sending out gas, heat, light, etc. It can also refer to harmful substances that are released into the environment, especially carbon dioxide.


This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">Environmental emission</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://dictionary.cambridge.org/dictionary/english/emission"/>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#EnvironmentalFootprint -->

    <owl:Class rdf:about="https://purl.org/eudpp#EnvironmentalFootprint">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#QuantitativeProperty"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (24)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Environmental footprint
means a quantification of the environmental impacts resulting from a product throughout its life
cycle, whether in relation to a single environmental impact category or an aggregated set of impact
categories based on the Product Environmental Footprint method established by Recommendation
(EU) 2 021/2279 or other scientific methods developed by international organisations, widely tested
in collaboration with different industry sectors and adopted or implemented by the Commission in
other Union law. (ESPR Art 2 (24)).

Product parameters list ESPR Annex I
(m) The environmental footprint of the product, expressed as a quantification;

This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">Environmental footprint</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#EnvironmentalPollution -->

    <owl:Class rdf:about="https://purl.org/eudpp#EnvironmentalPollution">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#QuantitativeProperty"/>
        <rdfs:comment xml:lang="en">Environmental pollution is the addition of any substance or form of energy to the environment at a rate faster than it can be dispersed or safely stored.

This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">Environmental pollution</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://www.britannica.com/science/pollution-environment"/>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#HazardousWasteAmount -->

    <owl:Class rdf:about="https://purl.org/eudpp#HazardousWasteAmount">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#WasteGenerationAmount"/>
        <rdfs:comment xml:lang="en">Hazardous waste amount of the product.

This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">Hazardous waste amount</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#Height -->

    <owl:Class rdf:about="https://purl.org/eudpp#Height">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#ProductDimension"/>
        <rdfs:comment xml:lang="en">Height of the product</rdfs:comment>
        <rdfs:label xml:lang="en">Height</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#LandUse -->

    <owl:Class rdf:about="https://purl.org/eudpp#LandUse">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#ResourceConsumption"/>
        <rdfs:comment xml:lang="en">Land use of the product.

This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">Land use</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#Length -->

    <owl:Class rdf:about="https://purl.org/eudpp#Length">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#ProductDimension"/>
        <rdfs:comment xml:lang="en">Length of the product</rdfs:comment>
        <rdfs:label xml:lang="en">Length</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#MaterialFootprint -->

    <owl:Class rdf:about="https://purl.org/eudpp#MaterialFootprint">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#EnvironmentalFootprint"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (26)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Material footprint
refers to the total amount of raw materials extracted to meet final consumption demands. (ESPR Art 2 (26))

This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">Material footprint</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#MicroplasticRelease -->

    <owl:Class rdf:about="https://purl.org/eudpp#MicroplasticRelease">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#PlasticsRelease"/>
        <dcterms:references xml:lang="en">ESPR Annex I</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Product parameters as listed in the ESPR Annex I :

(p) microplastic and nano plastic release as expressed through the release during relevant
product life cycle stages, including manufacturing, transport, use and end of life stages;

This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">Microplastic release</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#NanoplasticRelease -->

    <owl:Class rdf:about="https://purl.org/eudpp#NanoplasticRelease">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#PlasticsRelease"/>
        <dcterms:references xml:lang="en">ESPR Annex I</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Product parameters as listed in the ESPR Annex I :

(p) microplastic and nano plastic release as expressed through the release during relevant
product life cycle stages, including manufacturing, transport, use and end of life stages;

This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">Nanoplastic release</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#PackagingWasteAmount -->

    <owl:Class rdf:about="https://purl.org/eudpp#PackagingWasteAmount">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#WasteGenerationAmount"/>
        <rdfs:comment xml:lang="en">Packaging waste amount of the product.

This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">Packaging waste amount</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#PlasticsRelease -->

    <owl:Class rdf:about="https://purl.org/eudpp#PlasticsRelease">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#EnvironmentalPollution"/>
        <dcterms:references xml:lang="en">ESPR Annex I</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Product parameters as listed in the ESPR Annex I :

(p) microplastic and nano plastic release as expressed through the release during relevant
product life cycle stages, including manufacturing, transport, use and end of life stages;

This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">Plastic release</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#PlasticsWasteAmount -->

    <owl:Class rdf:about="https://purl.org/eudpp#PlasticsWasteAmount">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#WasteGenerationAmount"/>
        <rdfs:comment xml:lang="en">Hazardous waste amount of the product.

This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">Plastics waste amount</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#Product -->

    <owl:Class rdf:about="https://purl.org/eudpp#Product">
        <dcterms:references xml:lang="en">ESPR Art 2 (1)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Product means any physical goods that are placed on the market or put into service. ESPR Art 2 (1))</rdfs:comment>
        <rdfs:label xml:lang="en">Product</rdfs:label>
        <skos:closeMatch>schema:Product</skos:closeMatch>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#ProductDimension -->

    <owl:Class rdf:about="https://purl.org/eudpp#ProductDimension">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#QuantitativeProperty"/>
        <dcterms:references xml:lang="en">ESPR Annex I</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Dimension class covers measurements of length, width, height, volume, and weight of the product required by
ESPR Annex I in its product parameters</rdfs:comment>
        <rdfs:label xml:lang="en">Product dimension</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#ProductToPackagingRatio -->

    <owl:Class rdf:about="https://purl.org/eudpp#ProductToPackagingRatio">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#QuantitativeProperty"/>
        <dcterms:references xml:lang="en">ESPR Annex I</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">ESPR Annex I, the list of product parameters includes the parameter called the  product to packaging ratio.

However, it is not specified in ESPR  whether that ratio is defined on the basis of weight or on the basis of volume.

**This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.**</rdfs:comment>
        <rdfs:label xml:lang="en">Product to packaging ratio</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#Property -->

    <owl:Class rdf:about="https://purl.org/eudpp#Property">
        <rdfs:comment xml:lang="en">A property of the product.</rdfs:comment>
        <rdfs:label xml:lang="en">Property</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#QualityIndicator -->

    <owl:Class rdf:about="https://purl.org/eudpp#QualityIndicator">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#QuantitativeProperty"/>
        <rdfs:comment xml:lang="en">Product characteristics like durability and reliability.

This class description needs to be extended/specialised according to the corresponding delegated acts or/and industry standards.</rdfs:comment>
        <rdfs:label xml:lang="en">Quality indicator</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#QuantitativeProperty -->

    <owl:Class rdf:about="https://purl.org/eudpp#QuantitativeProperty">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Property"/>
        <rdfs:comment xml:lang="en">A property (respectively measurand of a property) of the product (model) that is expressed by a quantity value. A specific quantity.</rdfs:comment>
        <rdfs:label xml:lang="en">Quantitative Property</rdfs:label>
    </owl:Class>
    


