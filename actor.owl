<?xml version="1.0"?>
<rdf:RDF xmlns="https://purl.org/eudpp"
     xml:base="https://purl.org/eudpp"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:eudpp="https://purl.org/eudpp#"
     xmlns:eudpp1="https://purl.org/eudpp:"
     xmlns:schema="https://schema.org/"
     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://purl.org/eudpp/ACTOR">
        <dcterms:contributor xml:lang="en">Hele-Mai Haav</dcterms:contributor>
        <dcterms:contributor xml:lang="en">Tarmo Robal</dcterms:contributor>
        <dcterms:creator xml:lang="en">Riina Maigre</dcterms:creator>
        <dcterms:description xml:lang="en">Actor module of an EU DPP core ontology proposal of the CIRPASS-2 European project.

DEPENDENCIES:  This module has dependencies to the following EU DPP Core Ontology modules: CON, P_DPP, EVENT.  

For more information, see 
Maigre, R., Haav, H.-M., Robal, T., Wolf, M.-A., &amp;amp; Danash, F. (2025). Ontology Requirements Specification for an EU DPP Core Ontology Proposal (1.1). CIRPASS-2 Consortium. https://doi.org/10.5281/zenodo.15270342

=======================
CHANGES FEB 2026
1. Applied CEON-inspired design principles.
2. Modelled several Actor properties using schema.org properties, such as address, email, telephone, url, geo.
3. Changed Role class hierarchy.

CHANGES APRIL 2026
1. Moved identifier logic to connector.
2. Fixed AutorisedRepresentativeRoleAssignment name (previously AutorisedRepresentationAssignment).
        </dcterms:description>
        <dcterms:issued>2025-03-14</dcterms:issued>
        <dcterms:license rdf:resource="https://www.apache.org/licenses/LICENSE-2.0"/>
        <dcterms:license xml:lang="en">This ontology is licensed under the Apache License, Version 2.0. 
In case of dispute over Apache 2.0 applicability, or in case considering the ontology as a document, this ontology document is to be considered licensed under the Creative Commons Attribution 4.0 International (CC BY 4.0).</dcterms:license>
        <dcterms:modified>2026-04-23</dcterms:modified>
        <dcterms:title xml:lang="en">Actors and roles module for an EU DPP core ontology proposed by CIRPASS-2 European project.</dcterms:title>
        <vann:preferredNamespacePrefix>act</vann:preferredNamespacePrefix>
        <rdfs:comment xml:lang="en">The Actor module of an EU DPP core ontology proposed by the CIRPASS-2 European project.</rdfs:comment>
        <rdfs:label xml:lang="en">EU DPP CO ACTOR</rdfs:label>
        <owl:versionInfo>1.9.1</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/terms/contributor -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/contributor"/>
    


    <!-- http://purl.org/dc/terms/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/issued -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/issued"/>
    


    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/modified -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/modified"/>
    


    <!-- http://purl.org/dc/terms/references -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/references"/>
    


    <!-- http://purl.org/dc/terms/source -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/source"/>
    


    <!-- http://purl.org/dc/terms/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->

    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#definition -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#definition"/>
    
    

    <!-- https://purl.org/eudpp:references -->

    <owl:AnnotationProperty rdf:about="https://purl.org/eudpp:references"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2004/02/skos/core#broader -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#broader"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#related -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#related"/>
    


    <!-- https://purl.org/eudpp#hasActor -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasActor">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#ActorRoleAssignment"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Actor"/>
        <rdfs:comment xml:lang="en">Links actor role assignment to actor</rdfs:comment>
        <rdfs:label xml:lang="en">Has actor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasRepresentativeMandate -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasRepresentativeMandate">
        <owl:inverseOf rdf:resource="https://purl.org/eudpp#representsManufacturer"/>
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Actor"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#AuthorisedRepresentativeRoleAssignment"/>
        <rdfs:comment xml:lang="en">Relates a manufacturer to the mandate (assignment) that authorises an actor to act on the manufacturer&apos;s behalf.</rdfs:comment>
        <rdfs:label xml:lang="en">Has representative mandate</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasRole -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasRole">
        <owl:inverseOf rdf:resource="https://purl.org/eudpp#isRoleOf"/>
        <rdfs:domain rdf:resource="https://purl.org/eudpp#ActorRoleAssignment"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Role"/>
        <rdfs:comment xml:lang="en">Links an actor role assignment to a role.</rdfs:comment>
        <rdfs:label xml:lang="en">Has role</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#isEstablishedIn -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#isEstablishedIn">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LegalPerson"/>
        <rdfs:range rdf:resource="http://purl.org/dc/terms#Location"/>
        <rdfs:comment xml:lang="en">Relates a legal person to the location where it is established.</rdfs:comment>
        <rdfs:label xml:lang="en">Is established in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#isResidingIn -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#isResidingIn">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#NaturalPerson"/>
        <rdfs:range rdf:resource="http://purl.org/dc/terms#Location"/>
        <rdfs:comment xml:lang="en">Relates a natural person to the location where they reside.</rdfs:comment>
        <rdfs:label xml:lang="en">Is residing in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#isRoleOf -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#isRoleOf">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Role"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#ActorRoleAssignment"/>
        <rdfs:comment xml:lang="en">Relates role to an actor role assignment.</rdfs:comment>
        <rdfs:label xml:lang="en">Is role of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#isUsedByActor -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#isUsedByActor">
        <owl:inverseOf rdf:resource="https://purl.org/eudpp#usesFacility"/>
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Facility"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Actor"/>
        <rdfs:comment xml:lang="en">Relates a facility to an actor.</rdfs:comment>
        <rdfs:label xml:lang="en">Is used by actor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#representsManufacturer -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#representsManufacturer">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#AuthorisedRepresentativeRoleAssignment"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Actor"/>
        <rdfs:comment xml:lang="en">Used when the role is authorisedRepresentativeRole to indicate the manufacturer being represented.</rdfs:comment>
        <rdfs:label xml:lang="en">Represents manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#usesFacility -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#usesFacility">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Actor"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Facility"/>
        <rdfs:comment xml:lang="en">Relates an actor to facility.</rdfs:comment>
        <rdfs:label xml:lang="en">Uses facility</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.org/address -->

    <owl:ObjectProperty rdf:about="https://schema.org/address">
        <rdfs:comment xml:lang="en">Links an Actor or Facility to its postal address, represented as a schema:PostalAddress</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://schema.org/address"/>
        <rdfs:label xml:lang="en">Has address</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.org/geo -->

    <owl:ObjectProperty rdf:about="https://schema.org/geo">
        <rdfs:comment xml:lang="en">Links facility to its coordinates, represented as schema:geo.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://schema.org/geo"/>
        <rdfs:label xml:lang="en">Has coordinates</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://purl.org/eudpp#actorName -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#actorName">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Actor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Name of an actor.</rdfs:comment>
        <rdfs:label xml:lang="en">Actor name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#assignmentValidFrom -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#assignmentValidFrom">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#ActorRoleAssignment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The date and time from which the actor role assignment is valid.</rdfs:comment>
        <rdfs:label xml:lang="en">Assignment valid from</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#assignmentValidTo -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#assignmentValidTo">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#ActorRoleAssignment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The date and time until which the actor role assignment is valid.</rdfs:comment>
        <rdfs:label xml:lang="en">Assignment valid to</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#registeredTradeName -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#registeredTradeName">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Actor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Trade name under which a legal person or business operates and is registered.</rdfs:comment>
        <rdfs:label xml:lang="en">Registered trade name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#registeredTrademark -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#registeredTrademark">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Actor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A trademark officially registered and owned by an actor.</rdfs:comment>
        <rdfs:label xml:lang="en">Registered trademark</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.org/email -->

    <owl:DatatypeProperty rdf:about="https://schema.org/email">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Links an Actor to its email address.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://schema.org/email"/>
        <rdfs:label xml:lang="en">Has email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.org/latitude -->

    <owl:DatatypeProperty rdf:about="https://schema.org/latitude">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">Links facility to its coordinates. Part of schema:geo.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://schema.org/latitude"/>
        <rdfs:label xml:lang="en">latitude</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.org/longitude -->

    <owl:DatatypeProperty rdf:about="https://schema.org/longitude">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">Links facility to its coordinates. Part of schema:geo.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://schema.org/longitude"/>
        <rdfs:label xml:lang="en">longitude</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.org/telephone -->

    <owl:DatatypeProperty rdf:about="https://schema.org/telephone">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Links an Actor to its phone.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://schema.org/telephone"/>
        <rdfs:label xml:lang="en">Has phone</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.org/url -->

    <owl:DatatypeProperty rdf:about="https://schema.org/url">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">The official website or webpage of the actor.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://schema.org/url"/>
        <rdfs:label xml:lang="en">URL</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/terms#Location -->

    <owl:Class rdf:about="http://purl.org/dc/terms#Location">
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms#Location"/>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#Actor -->

    <owl:Class rdf:about="https://purl.org/eudpp#Actor">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://schema.org/address"/>
                <owl:allValuesFrom rdf:resource="https://schema.org/PostalAddress"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:references xml:lang="en">CIRPASS-2 User Stories 3.1</dcterms:references>
        <dcterms:source>https://zenodo.org/records/17979585</dcterms:source>
        <rdfs:comment xml:lang="en">Actor means a legal or natural person (e.g. John Doe, TNO). One actor can take on multiple roles; [CIRPASS-2 User Stories 3.1]</rdfs:comment>
        <rdfs:label xml:lang="en">Actor</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#ActorRoleAssignment -->

    <owl:Class rdf:about="https://purl.org/eudpp#ActorRoleAssignment">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eudpp#hasRole"/>
                <owl:allValuesFrom rdf:resource="https://purl.org/eudpp#Role"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Assigns a role to the actor in a particular context (DPP, Product, Event).</rdfs:comment>
        <rdfs:label xml:lang="en">Actor role assignment</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#AuthorisedRepresentativeRoleAssignment -->

    <owl:Class rdf:about="https://purl.org/eudpp#AuthorisedRepresentativeRoleAssignment">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#ActorRoleAssignment"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eudpp#hasRole"/>
                <owl:hasValue rdf:resource="https://purl.org/eudpp#authorisedRepresentative"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:references xml:lang="en">ESPR Art 2 (43)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">A specific assignment representing the written mandate between a manufacturer and an authorised representative; [ESPR Art 2 (43)]</rdfs:comment>
        <rdfs:label xml:lang="en">Authorised representative role assignment</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#AuthorityRole -->

    <owl:Class rdf:about="https://purl.org/eudpp#AuthorityRole">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Role"/>
        <rdfs:comment xml:lang="en">Parent class for roles of authorities, such as market surveillance authority, customs authority, etc.</rdfs:comment>
        <rdfs:label xml:lang="en">Authority role</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#CircularEconomyRole -->

    <owl:Class rdf:about="https://purl.org/eudpp#CircularEconomyRole">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Role"/>
        <rdfs:comment xml:lang="en">Parent class for roles related to circular economy, such as remanufacturer, refurbisher, etc.</rdfs:comment>
        <rdfs:label xml:lang="en">Circular economy role</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#ConformityAssessmentRole -->

    <owl:Class rdf:about="https://purl.org/eudpp#ConformityAssessmentRole">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Role"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (51)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Conformity assessment means the process demonstrating whether the ecodesign requirements set out in the relevant delegated acts adopted pursuant to Article 4 have been fulfilled; [ESPR Art 2 (51)]</rdfs:comment>
        <rdfs:label xml:lang="en">Conformity assessment role</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#EconomicOperatorRole -->

    <owl:Class rdf:about="https://purl.org/eudpp#EconomicOperatorRole">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Role"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (46)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Economic operator means the manufacturer, the authorised representative, the importer, the distributor, the dealer and the fulfilment service provider; [ESPR Art 2 (46)]</rdfs:comment>
        <rdfs:label xml:lang="en">Economic operator role</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#EndUserRole -->

    <owl:Class rdf:about="https://purl.org/eudpp#EndUserRole">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Role"/>
        <rdfs:comment xml:lang="en">Parent class for roles of end users, such as consumer, etc.</rdfs:comment>
        <rdfs:label xml:lang="en">End user role</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#Facility -->

    <owl:Class rdf:about="https://purl.org/eudpp#Facility">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://schema.org/address"/>
                <owl:allValuesFrom rdf:resource="https://schema.org/PostalAddress"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://schema.org/geo"/>
                <owl:allValuesFrom rdf:resource="https://schema.org/GeoCoordinates"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:source>https://marketbusinessnews.com/financial-glossary/facility/</dcterms:source>
        <rdfs:comment xml:lang="en">A Facility may be a place where specific activities occur. A production/manufacturing facility means a factory. The term may refer to any place that makes things, or plants that generate electricity.</rdfs:comment>
        <rdfs:comment xml:lang="en">Business facilities are structures that provide services to a business. This can include space for employees, technology, equipment and inventory. Facilities can be used for business administration, operations or to provide services to customers.</rdfs:comment>
        <rdfs:label xml:lang="en">Facility</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#LegalPerson -->

    <owl:Class rdf:about="https://purl.org/eudpp#LegalPerson">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Actor"/>
        <owl:disjointWith rdf:resource="https://purl.org/eudpp#NaturalPerson"/>
        <dcterms:source>https://www.merriam-webster.com/legal/legal%20person</dcterms:source>
        <rdfs:comment xml:lang="en">A body of persons or an entity (as a corporation) considered as having many of the rights and responsibilities of a natural person and especially the capacity to sue and be sued.</rdfs:comment>
        <rdfs:label xml:lang="en">Legal Person</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#NaturalPerson -->

    <owl:Class rdf:about="https://purl.org/eudpp#NaturalPerson">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Actor"/>
        <dcterms:source>https://www.merriam-webster.com/legal/natural%20person</dcterms:source>
        <rdfs:comment xml:lang="en">A human being as distinguished from a person (as a corporation) created by operation of law</rdfs:comment>
        <rdfs:label xml:lang="en">Natural Person</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#Role -->

    <owl:Class rdf:about="https://purl.org/eudpp#Role">
        <dcterms:references xml:lang="en">CIRPASS-2 User Stories 3.1</dcterms:references>
        <dcterms:source>https://zenodo.org/records/17979585</dcterms:source>
        <rdfs:comment xml:lang="en">Role means a set of tasks typically performed by one actor. (e.g. Responsible Economic Operator, Independent operator); [CIRPASS-2 User Stories 3.1]</rdfs:comment>
        <rdfs:label xml:lang="en">Role</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.org/GeoCoordinates -->

    <owl:Class rdf:about="https://schema.org/GeoCoordinates">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://schema.org/latitude"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://schema.org/longitude"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://schema.org/GeoCoordinates"/>
    </owl:Class>
    


    <!-- https://schema.org/PostalAddress -->

    <owl:Class rdf:about="https://schema.org/PostalAddress">
        <rdfs:isDefinedBy rdf:resource="https://schema.org/PostalAddress"/>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://publications.europa.eu/resource/authority/corporate-body/COM -->

    <owl:NamedIndividual rdf:about="http://publications.europa.eu/resource/authority/corporate-body/COM">
        <owl:sameAs rdf:resource="https://purl.org/eudpp#EuropeanCommission"/>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#EuropeanCommission -->

    <rdf:Description rdf:about="https://purl.org/eudpp#EuropeanCommission"/>
    


    <!-- http://publications.europa.eu/resource/authority/country/EUR -->

    <owl:NamedIndividual rdf:about="http://publications.europa.eu/resource/authority/country/EUR">
        <rdfs:comment xml:lang="en">European Union is used here as a jurisdictional or geographic entity for legal and regulatory contexts.</rdfs:comment>
        <rdfs:label xml:lang="en">European Union</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#EuropeanCommission -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#EuropeanCommission">
        <rdf:type rdf:resource="https://purl.org/eudpp#LegalPerson"/>
        <dcterms:source>https://ec.europa.eu/eurostat/statistics-explained/index.php?title=Glossary:European_Commission_(EC)</dcterms:source>
        <rdfs:comment xml:lang="en">The European Commission, abbreviated as EC, is the executive branch of the European Union.</rdfs:comment>
        <rdfs:label xml:lang="en">European Commission</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#authorisedRepresentative -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#authorisedRepresentative">
        <rdf:type rdf:resource="https://purl.org/eudpp#EconomicOperatorRole"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (43)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Authorised representative means any natural or legal person established in the Union that has received a written mandate from the manufacturer to act on the manufacturer’s behalf in relation to specified tasks with regard to the manufacturer’s obligations under this Regulation; [ESPR Art 2 (43)]</rdfs:comment>
        <rdfs:label xml:lang="en">Authorised Representative</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#conformityAssessmentBody -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#conformityAssessmentBody">
        <rdf:type rdf:resource="https://purl.org/eudpp#ConformityAssessmentRole"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (52)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Conformity assessment body means a body that performs conformity assessment activities including calibration, testing, certification and inspection; [ESPR Art 2 (52)]</rdfs:comment>
        <rdfs:label xml:lang="en">Conformity Assessment Body</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#consumer -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#consumer">
        <rdf:type rdf:resource="https://purl.org/eudpp#EndUserRole"/>
        <skos:broader rdf:resource="https://purl.org/eudpp#customer"/>
        <dcterms:references xml:lang="en">Directive (EU) 2019/771, Art 2 (2)</dcterms:references>
        <dcterms:source>http://data.europa.eu/eli/dir/2019/771/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Consumer means any natural person who, in relation to contracts covered by Directive (EU) 2019/771, is acting for purposes which are outside that person&apos;s trade, business, craft or profession; [Directive (EU) 2019/771, Art 2 (2)]</rdfs:comment>
        <rdfs:label xml:lang="en">Consumer</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#credentialAgency -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#credentialAgency">
        <rdf:type rdf:resource="https://purl.org/eudpp#Role"/>
        <dcterms:references xml:lang="en">CIRPASS-2 User Stories 3.1</dcterms:references>
        <dcterms:source>https://zenodo.org/records/17979585</dcterms:source>
        <rdfs:comment xml:lang="en">A legal person that provides (professional) credentials to parties, which may be used to make and verify a variety of claims in the DPP, (ESPR) Art. 11 last paragraph. For example, a credentials agency could certify a professional repairer and provide appropriate credentials for the DPP system; [CIRPASS-2 User Stories 3.1]</rdfs:comment>
        <rdfs:label xml:lang="en">Credential Agency</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#customer -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#customer">
        <rdf:type rdf:resource="https://purl.org/eudpp#EndUserRole"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (35)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Customer means a natural or legal person that purchases, hires or receives a product for their own use whether or not acting for purposes which are outside their trade, business, craft or profession; [ESPR Art 2 (35)]</rdfs:comment>
        <rdfs:label xml:lang="en">Customer</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#customsAuthority -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#customsAuthority">
        <rdf:type rdf:resource="https://purl.org/eudpp#AuthorityRole"/>
        <dcterms:references xml:lang="en">Regulation (EU) 2019/1020, Art 3 (24)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2019/1020/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Customs authorities means  customs authorities as defined in point 1 of Article 5 of Regulation (EU) No 952/2013; [Regulation (EU) 2019/1020, Art 3 (24)]</rdfs:comment>
        <rdfs:comment xml:lang="en">Customs authorities means the customs administrations of the Member States responsible for applying the customs legislation and any other authorities empowered under national law to apply certain customs legislation (Regulation (EU) No 952/2013 Art 5 (1);</rdfs:comment>
        <rdfs:label xml:lang="en">Customs Authority</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#dealer -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#dealer">
        <rdf:type rdf:resource="https://purl.org/eudpp#EconomicOperatorRole"/>
        <skos:related rdf:resource="https://purl.org/eudpp#distributor"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (55)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Dealer means a distributor or any other natural or legal person that offers products for sale, hire or hire purchase, or that displays products, to end users in the course of a commercial activity, including through distance selling; and includes any natural or legal person that puts a product into service in the course of a commercial activity; [ESPR Art 2 (55)]</rdfs:comment>
        <rdfs:label xml:lang="en">Dealer</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#distributor -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#distributor">
        <rdf:type rdf:resource="https://purl.org/eudpp#EconomicOperatorRole"/>
        <skos:related rdf:resource="https://purl.org/eudpp#dealer"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (45)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Distributor means any natural or legal person in the supply chain, other than the manufacturer or the importer, that makes a product available on the market; [ESPR Art 2 (45)]</rdfs:comment>
        <rdfs:label xml:lang="en">Distributor</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#dppServiceProvider -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#dppServiceProvider">
        <rdf:type rdf:resource="https://purl.org/eudpp#Role"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (32)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Digital product passport service provider means a natural or legal person that is an independent third-party authorised by the economic operator which places the product on the market or puts it into service and that processes the digital product passport data for that product for the purpose of making such data available to economic operators and other relevant actors with a right to access those data under this Regulation or other Union law; [ESPR Art 2 (32)]</rdfs:comment>
        <rdfs:label xml:lang="en">DPP Service Provider</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#endUser -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#endUser">
        <rdf:type rdf:resource="https://purl.org/eudpp#EndUserRole"/>
        <skos:related rdf:resource="https://purl.org/eudpp#customer"/>
        <dcterms:references xml:lang="en">Regulation (EU) 2019/1020, Art 3 (21)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2019/1020/oj</dcterms:source>
        <rdfs:comment xml:lang="en">End user means any natural or legal person residing or established in the Union, to whom a product has been made available either as a consumer outside of any trade, business, craft or profession or as a professional end user in the course of its industrial or professional activities; [Regulation (EU) 2019/1020  Art 3 (21)]</rdfs:comment>
        <rdfs:label xml:lang="en">End User</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#fulfilmentServiceProvider -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#fulfilmentServiceProvider">
        <rdf:type rdf:resource="https://purl.org/eudpp#EconomicOperatorRole"/>
        <dcterms:references xml:lang="en">Regulation (EU) 2019/1020, Art 3 (11)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2019/1020/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Fulfilment service provider means any natural or legal person offering, in the course of commercial activity, at least two of the following services: warehousing, packaging, addressing and dispatching, without having ownership of the products involved, excluding postal services as defined in point 1 of Article 2 of Directive 97/67/EC of the European Parliament and of the Council (31), parcel delivery services as defined in point 2 of Article 2 of Regulation (EU) 2018/644 of the European Parliament and of the Council (32), and any other postal services or freight transport services; [Regulation (EU) 2019/1020 Art 3 (11)].</rdfs:comment>
        <rdfs:label xml:lang="en">Fulfilment Service Provider</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#importer -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#importer">
        <rdf:type rdf:resource="https://purl.org/eudpp#EconomicOperatorRole"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (44)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Importer means any natural or legal person established in the Union that places a product from a third country on the Union market; [ESPR Art 2 (44)]</rdfs:comment>
        <rdfs:label xml:lang="en">Importer</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#independentOperator -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#independentOperator">
        <rdf:type rdf:resource="https://purl.org/eudpp#CircularEconomyRole"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (47)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Independent operator means natural or legal person that is independent of the manufacturer and is directly or indirectly involved in the refurbishment, repair, maintenance or repurposing of a product, and includes waste management operators, refurbishers, repairers, manufacturers or distributors of repair equipment, tools or spare parts, as well as publishers of technical information, operators offering inspection and testing services and operators offering training for installers, manufacturers and repairers of equipment; [ESPR Art 2 (47)]</rdfs:comment>
        <rdfs:label xml:lang="en">Independent Operator</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#issuingAgency -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#issuingAgency">
        <rdf:type rdf:resource="https://purl.org/eudpp#Role"/>
        <dcterms:references xml:lang="en">ESPR Art 12 (4a)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Issuing agency is a legal persons that provide unique identifiers and data carriers Art 12 (4a). Under specific conditions, economic operators may perform the functions associated with an Issuing Agency; [ESPR Art 12 (4b)]</rdfs:comment>
        <rdfs:label xml:lang="en">Issuing Agency</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#manufacturer -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#manufacturer">
        <rdf:type rdf:resource="https://purl.org/eudpp#EconomicOperatorRole"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (42)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Manufacturer means any natural or legal person that manufactures a product or that has a product designed or manufactured and markets that product under their name or trademark; [ESPR Art 2 (42)]</rdfs:comment>
        <rdfs:label xml:lang="en">Manufacturer</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#marketSurveillanceAuthority -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#marketSurveillanceAuthority">
        <rdf:type rdf:resource="https://purl.org/eudpp#AuthorityRole"/>
        <dcterms:references xml:lang="en">Regulation (EU) 2019/1020, Art 3 (4)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2019/1020/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Market surveillance authority means an authority designated by a Member State under Article 10 as responsible for carrying out market surveillance in the territory of that Member State; [Regulation (EU) 2019/1020 Art 3 (4)]</rdfs:comment>
        <rdfs:label xml:lang="en">Market Surveillance Authority</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#notifiedBody -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#notifiedBody">
        <rdf:type rdf:resource="https://purl.org/eudpp#ConformityAssessmentRole"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (53)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Notified body means a conformity assessment body notified in accordance with Chapter IX.; [ESPR Art 2 (53)]</rdfs:comment>
        <rdfs:label xml:lang="en">Notified Body</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#professionalRepairer -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#professionalRepairer">
        <rdf:type rdf:resource="https://purl.org/eudpp#CircularEconomyRole"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (48)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Professional repairer means a natural or legal person that provides professional repair or maintenance services for a product, irrespective of whether that person acts within the manufacturer’s distribution system or independently; [ESPR Art 2 (48)]</rdfs:comment>
        <rdfs:label xml:lang="en">Professional Repairer</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#recycler -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#recycler">
        <rdf:type rdf:resource="https://purl.org/eudpp#CircularEconomyRole"/>
        <skos:broader rdf:resource="https://purl.org/eudpp#independentOperator"/>
        <dcterms:references xml:lang="en">WFD Art 3 (17)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/dir/2008/98/oj</dcterms:source>
        <rdfs:comment xml:lang="en">An actor performing recycling, which means &quot;any recovery operation by which waste materials are reprocessed into products, materials or substances whether for the original or other purposes. It includes the reprocessing of organic material but does not include energy recovery and the reprocessing into materials that are to be used as fuels or for backfilling operations&quot; [WFD Art 3 (17)]</rdfs:comment>
        <rdfs:label xml:lang="en">Recycler</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#refurbisher -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#refurbisher">
        <rdf:type rdf:resource="https://purl.org/eudpp#CircularEconomyRole"/>
        <skos:broader rdf:resource="https://purl.org/eudpp#independentOperator"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (18)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">An actor performing refurbishment, which means &quot;actions carried out to prepare, clean, test, service and, where necessary, repair a product or a discarded product in order to restore its performance or functionality within the intended use and range of performance originally conceived at the design stage at the time of the placing of the product on the market.&quot;; [ESPR Art 2 (18)]</rdfs:comment>
        <rdfs:label xml:lang="en">Refurbisher</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#remanufacturer -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#remanufacturer">
        <rdf:type rdf:resource="https://purl.org/eudpp#CircularEconomyRole"/>
        <skos:broader rdf:resource="https://purl.org/eudpp#manufacturer"/>
        <dcterms:references xml:lang="en">ESPR Art 2 (16)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">An actor performing remanufacturing, which means &quot;actions through which a new product is produced from objects that are waste, products or components and through which at least one change is made that substantially affects the safety, performance, purpose or type of the product&quot;; [ESPR Art 2 (16)]</rdfs:comment>
        <rdfs:label xml:lang="en">Remanufacturer</rdfs:label>
    </owl:NamedIndividual>
</rdf:RDF>



