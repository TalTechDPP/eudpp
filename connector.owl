    <!-- http://www.w3.org/2001/XMLSchema#date -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://purl.org/eudpp#containsLcaResult -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#containsLcaResult">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#DPP"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#LcaResult"/>
        <rdfs:comment xml:lang="en">A DPP contains a LCA Result -- a measurable outcome of a life cycle assessment, representing the quantified effect of a product.

DPP is modelled in the EU DPP CO P_DPP module.
LcaResult is modelled in the EU DPP CO LCA module.</rdfs:comment>
        <rdfs:label xml:lang="en">Contains LCA result</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#containsSubstanceOfConcern -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#containsSubstanceOfConcern">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://purl.org/eudpp#MaterialOfComposition"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#Product"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://purl.org/eudpp#SubstanceOfConcern"/>
        <rdfs:comment xml:lang="en">Linking the product to a substance of concern the product contains.

Product is modelled in the EU DPP CO P_DPP module.
Substance of concern is modelled in the EU DPP CO SOC module.</rdfs:comment>
        <rdfs:label xml:lang="en">Contains substance of concern</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasBackUpCopyHost -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasBackUpCopyHost">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#DPP"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Actor"/>
        <dcterms:references>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:references>
        <dcterms:source>ESPR Annex III</dcterms:source>
        <rdfs:comment xml:lang="en">The reference of the digital product passport service provider hosting the back-up copy of the digital product passport [ESPR Annex III].

DPP is modelled in the EU DPP CO P_DPP module.
Actor is modelled in the EU DPP CO ACTOR module.</rdfs:comment>
        <rdfs:label xml:lang="en">Has back-up-copy host</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasDigitalProductPassportId -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasDigitalProductPassportId">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#DPP"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#DPPIdentifier"/>
        <rdfs:comment>Realisation for the Unique identifier of an instance of the digital product passport.

DPP is modelled in the EU DPP CO P_DPP module.
DPPIdentifier is modelled in the EU DPP CO IDENT module.</rdfs:comment>
        <rdfs:label xml:lang="en">Has digital product passport id</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasEconomicOperator -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasEconomicOperator">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Actor"/>
        <rdfs:comment xml:lang="en">Linking the product to the economic operator (Actor from ACTOR module).

Product is modelled in the EU DPP CO P_DPP module.
Actor is modelled in the EU DPP CO ACTOR module.</rdfs:comment>
        <rdfs:label xml:lang="en">Has economic operator</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasIssuer -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasIssuer">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#DPP"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Actor"/>
        <rdfs:comment xml:lang="en">Linking DPP with its issuer (Actor from ACTOR module).

DPP is modelled in the EU DPP CO P_DPP module.
Actor is modelled in the EU DPP CO ACTOR module.</rdfs:comment>
        <rdfs:label xml:lang="en">Has issuer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasLcaResult -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasLcaResult">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#LcaResult"/>
        <rdfs:comment xml:lang="en">A product has a LCA Result -- a measurable outcome of a life cycle assessment, representing the quantified effect of a product.

Product is modelled in the EU DPP CO P_DPP module.
LcaResult is modelled in the EU DPP CO LCA module.</rdfs:comment>
        <rdfs:label xml:lang="en">Has LCA result</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasManufacturer -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasManufacturer">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Actor"/>
        <rdfs:comment xml:lang="en">A product has a manufacturer (Actor from ACTOR module).

Product is modelled in the EU DPP CO P_DPP module.
Actor is modelled in the EU DPP CO ACTOR module.</rdfs:comment>
        <rdfs:label xml:lang="en">Has manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasMaterial -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasMaterial">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#MaterialOfComposition"/>
        <rdfs:comment xml:lang="en">Linking the Product to a MaterialOfComposition.

Product is modelled in the EU DPP CO P_DPP module.
MaterialOfComposition is modelled in the EU DPP CO MAT module.</rdfs:comment>
        <rdfs:label xml:lang="en">Has material</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasMaterialIdentifier -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasMaterialIdentifier">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#MaterialOfComposition"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#MaterialIdentifier"/>
        <rdfs:comment xml:lang="en">Realisation of thematerial indetifier as &quot;Product parameters: identification of  ... materials [ESPR Annex I c)]&quot;

MaterialOfComposition is modelled in the EU DPP CO MAT module.
MaterialIdentifier is modelled in the EU DPP CO IDENT module.</rdfs:comment>
        <rdfs:label xml:lang="en">Has material identifier</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasUniqueProductIdentifier -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasUniqueProductIdentifier">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#ProductIdentifier"/>
        <rdfs:comment xml:lang="en">Realisation of the uniqueProductIdentifier.

Product is modelled in the EU DPP CO P_DPP module.
ProductIdentifier is modelled in the EU DPP CO IDENT module.</rdfs:comment>
        <rdfs:label xml:lang="en">Has unique product identifier</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#inContextOfActivity -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#inContextOfActivity">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#ActorRoleAssignment"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Event"/>
        <rdfs:comment xml:lang="en">Relates the actor role assignment to a specific lifecycle activity, such as a repair or recycling event (from the Event module).
        
ActorRoleAssignment is modelled in the EU DPP CO ACTOR module.
Event is modelled in the EU DPP CO EVENT module.
        </rdfs:comment>
        <rdfs:label xml:lang="en">In context of activity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#inContextOfDPP -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#inContextOfDPP">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#ActorRoleAssignment"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#DPP"/>
        <rdfs:comment xml:lang="en">Relates the actor role assignment to a specific Digital Product Passport instance (from P_DPP module).

ActorRoleAssignment is modelled in the EU DPP CO ACTOR module.
DPP is modelled in the EU DPP CO P_DPP module.
        </rdfs:comment>
        <rdfs:label xml:lang="en">In context of DPP</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#inContextOfProduct -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#inContextOfProduct">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#ActorRoleAssignment"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:comment xml:lang="en">Relates the actor role assignment to a specific product (from P_DPP module).

ActorRoleAssignment is modelled in the EU DPP CO ACTOR module.
Product is modelled in the EU DPP CO P_DPP module.</rdfs:comment>
        <rdfs:label xml:lang="en">In context of product</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#isConnectedTo -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#isConnectedTo">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#DPP"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Facility"/>
        <rdfs:comment xml:lang="en">A DPP is connected to a facility.

DPP is modelled in the EU DPP CO P_DPP module.
Facility is modelled in the EU DPP CO ACTOR module.</rdfs:comment>
        <rdfs:label xml:lang="en">Is connected to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#representsManufacturerForProduct -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#representsManufacturerForProduct">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#AuthorisedRepresentationAssignment"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Product"/>
        <rdfs:comment xml:lang="en">Indicates which product(s) the authorised representative&apos;s mandate covers.

AuthorisedRepresentationAssignment is modelled in the EU DPP CO ACTOR module.
Product is modelled in the EU DPP CO P_DPP module.</rdfs:comment>
        <rdfs:label xml:lang="en">Represents manufacturer for product</rdfs:label>
    </owl:ObjectProperty>
    


