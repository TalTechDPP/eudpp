    </owl:Class>
    


    <!-- https://purl.org/eudpp#Event -->

    <owl:Class rdf:about="https://purl.org/eudpp#Event">
        <rdfs:isDefinedBy rdf:resource="https://purl.org/eudpp/EVENT"/>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#Facility -->

    <owl:Class rdf:about="https://purl.org/eudpp#Facility">
        <rdfs:isDefinedBy rdf:resource="https://purl.org/eudpp/ACTOR"/>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#LcaResult -->

    <owl:Class rdf:about="https://purl.org/eudpp#LcaResult">
        <rdfs:isDefinedBy>https://purl.org/eudpp/LCA</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#MaterialIdentifier -->

    <owl:Class rdf:about="https://purl.org/eudpp#MaterialIdentifier">
        <rdfs:isDefinedBy>https://purl.org/eudpp/IDENT</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#MaterialOfComposition -->

    <owl:Class rdf:about="https://purl.org/eudpp#MaterialOfComposition">
        <rdfs:isDefinedBy>https://purl.org/eudpp/MAT</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#Product -->

    <owl:Class rdf:about="https://purl.org/eudpp#Product">
        <rdfs:isDefinedBy rdf:resource="https://purl.org/eudpp/P_DPP"/>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#ProductIdentifier -->

    <owl:Class rdf:about="https://purl.org/eudpp#ProductIdentifier">
        <rdfs:isDefinedBy>https://purl.org/eudpp/IDENT</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#SubstanceOfConcern -->

    <owl:Class rdf:about="https://purl.org/eudpp#SubstanceOfConcern">
        <rdfs:isDefinedBy rdf:resource="https://purl.org/eudpp/SOC"/>
    </owl:Class>
