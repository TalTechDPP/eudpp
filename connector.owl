     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://purl.org/eudpp/CONNECTOR">
        <dcterms:created xml:lang="en">2025-02-27</dcterms:created>
        <dcterms:creator xml:lang="en">Riina Maigre</dcterms:creator>
        <dcterms:creator xml:lang="en">Tarmo Robal</dcterms:creator>
        <dcterms:description xml:lang="en">Connector (Bridge) module that only defines object properties between modules. The connector contains only object properties that have domain and range specified in different modules. 

--
THIS DOCUMENT IS PROVIDED WITH NO WARRANTIES WHATSOEVER. 
All liability for any damages arising from use or misuse of this vocabulary is with the user.</dcterms:description>
        <dcterms:issued xml:lang="en">2026-04-23</dcterms:issued>
        <dcterms:licence rdf:resource="https://www.apache.org/licenses/LICENSE-2.0"/>
        <dcterms:licence xml:lang="en">This ontology is licensed under the Apache License, Version 2.0. 
In case of dispute over Apache 2.0 applicability, or in case considering the ontology as a document, this ontology document is to be considered licensed under the Creative Commons Attribution 4.0 International (CC BY 4.0).</dcterms:licence>
        <dcterms:title xml:lang="en">The connector module of the EU regulatory compliant Digital Product Passport Core Ontology (EU DPP CO) proposed by the CIRPASS-2 European project.</dcterms:title>
        <vann1:preferredNamespacePrefix>con</vann1:preferredNamespacePrefix>
        <rdfs:comment xml:lang="en">The CONNECTOR module of the EU DPP core ontology proposal of the CIRPASS-2 European project.</rdfs:comment>
        <rdfs:label xml:lang="en">EU DPP CORE CONNECTOR</rdfs:label>
        <owl:versionInfo>1.9.2</owl:versionInfo>
    </owl:Ontology>
    


