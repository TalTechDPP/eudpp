    <!-- https://purl.org/eudpp#identifierExampleValue -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#identifierExampleValue">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#IdentifierScheme"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Example value of the identifier</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#identifierMaxLength -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#identifierMaxLength">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#IdentifierScheme"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Maximum length of the identifier</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#identifierMinLength -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#identifierMinLength">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#IdentifierScheme"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Minimum length of the identifier</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#identifierValue -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#identifierValue">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Identifier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The (unique) value of the identifier.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/eudpp#identifierSchemeVersion -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/eudpp#identifierSchemeVersion">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#IdentifierScheme"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Reference standard version the instance schema refers to</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://purl.org/eudpp#ActorIdentifier -->

    <owl:Class rdf:about="https://purl.org/eudpp#ActorIdentifier">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Identifier"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eudpp#hasScheme"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eudpp#ActorIdentifierScheme"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eudpp#identifierValue"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://purl.org/eudpp#DPPIdentifier"/>
        <owl:disjointWith rdf:resource="https://purl.org/eudpp#FacilityIdentifier"/>
        <owl:disjointWith rdf:resource="https://purl.org/eudpp#MaterialIdentifier"/>
        <owl:disjointWith rdf:resource="https://purl.org/eudpp#ProductIdentifier"/>
        <owl:disjointWith rdf:resource="https://purl.org/eudpp#SoCIdentifier"/>
        <rdfs:label xml:lang="en">Actor identifier</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#ActorIdentifierScheme -->

    <owl:Class rdf:about="https://purl.org/eudpp#ActorIdentifierScheme">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#IdentifierScheme"/>
        <owl:disjointWith rdf:resource="https://purl.org/eudpp#MaterialIdentifierScheme"/>
        <owl:disjointWith rdf:resource="https://purl.org/eudpp#ProductIdentifierScheme"/>
        <rdfs:label xml:lang="en">Actor identifier scheme</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#DPPIdentifier -->

    <owl:Class rdf:about="https://purl.org/eudpp#DPPIdentifier">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Identifier"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eudpp#identifierValue"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://purl.org/eudpp#FacilityIdentifier"/>
        <owl:disjointWith rdf:resource="https://purl.org/eudpp#MaterialIdentifier"/>
        <owl:disjointWith rdf:resource="https://purl.org/eudpp#ProductIdentifier"/>
        <owl:disjointWith rdf:resource="https://purl.org/eudpp#SoCIdentifier"/>
        <rdfs:label xml:lang="en">DPP identifier</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#FacilityIdentifier -->

    <owl:Class rdf:about="https://purl.org/eudpp#FacilityIdentifier">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Identifier"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eudpp#identifierValue"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://purl.org/eudpp#MaterialIdentifier"/>
        <owl:disjointWith rdf:resource="https://purl.org/eudpp#ProductIdentifier"/>
        <owl:disjointWith rdf:resource="https://purl.org/eudpp#SoCIdentifier"/>
        <rdfs:comment xml:lang="en">A unique code assigned to a physical site (factory, warehouse, plant, school, hospital, etc.), i.e., identifies a location.</rdfs:comment>
        <rdfs:label xml:lang="en">Facility identifier</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#Identifier -->

    <owl:Class rdf:about="https://purl.org/eudpp#Identifier">
        <rdfs:comment xml:lang="en">Identifier. A general class to hold different kinds of identifiers described and used for EU DPP CO. Each sub-class of this class describes a different kind of identifier. Intentionally modelled as sub-classes. 
Identifiers have value, and a scheme/standard they are based on.

Cardinatlity restrictions added to each subclass to enforce inheritance of the data propertyy identifierValue.</rdfs:comment>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#IdentifierGranularity -->

    <owl:Class rdf:about="https://purl.org/eudpp#IdentifierGranularity">
        <rdfs:comment xml:lang="en">The granularity of the identifier. For example, for Productys this could be model, batch, item.</rdfs:comment>
        <rdfs:label xml:lang="en">Identifier granularity</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#IdentifierScheme -->

    <owl:Class rdf:about="https://purl.org/eudpp#IdentifierScheme">
        <rdfs:comment xml:lang="en">The scheme or standard</rdfs:comment>
        <rdfs:label xml:lang="en">Identifier scheme</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#MaterialIdentifier -->

    <owl:Class rdf:about="https://purl.org/eudpp#MaterialIdentifier">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Identifier"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eudpp#hasScheme"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eudpp#MaterialIdentifierScheme"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eudpp#identifierValue"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://purl.org/eudpp#ProductIdentifier"/>
        <owl:disjointWith rdf:resource="https://purl.org/eudpp#SoCIdentifier"/>
        <rdfs:label xml:lang="en">Material identifier</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#MaterialIdentifierScheme -->

    <owl:Class rdf:about="https://purl.org/eudpp#MaterialIdentifierScheme">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#IdentifierScheme"/>
        <owl:disjointWith rdf:resource="https://purl.org/eudpp#ProductIdentifierScheme"/>
        <rdfs:label xml:lang="en">Material identifier scheme</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#ProductIdentifier -->

    <owl:Class rdf:about="https://purl.org/eudpp#ProductIdentifier">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Identifier"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eudpp#hasScheme"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/eudpp#ProductIdentifierScheme"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eudpp#hasGranularity"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://purl.org/eudpp#ProductIdentifierGranularity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eudpp#identifierValue"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://purl.org/eudpp#SoCIdentifier"/>
        <rdfs:label xml:lang="en">Product identifier</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#ProductIdentifierGranularity -->

    <owl:Class rdf:about="https://purl.org/eudpp#ProductIdentifierGranularity">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://purl.org/eudpp#batch"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#item"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#model"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#IdentifierGranularity"/>
        <rdfs:label xml:lang="en">Product identifier granularity</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#ProductIdentifierScheme -->

    <owl:Class rdf:about="https://purl.org/eudpp#ProductIdentifierScheme">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#IdentifierScheme"/>
        <rdfs:label xml:lang="en">Product identifier scheme</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#SoCIdentifier -->

    <owl:Class rdf:about="https://purl.org/eudpp#SoCIdentifier">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Identifier"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eudpp#identifierValue"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Substance of concern identifier</rdfs:label>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://purl.org/eudpp#CAS -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#CAS">
        <rdf:type rdf:resource="https://purl.org/eudpp#MaterialIdentifierScheme"/>
        <eudpp:identifierExampleValue>7732-18-5</eudpp:identifierExampleValue>
        <eudpp:identifierMaxLength rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">12</eudpp:identifierMaxLength>
        <eudpp:identifierMinLength rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">7</eudpp:identifierMinLength>
        <rdfs:comment xml:lang="en">CAS Number (Chemical Abstracts Service)</rdfs:comment>
        <rdfs:label xml:lang="en">CAS</rdfs:label>
        <rdfs:seeAlso>https://www.cas.org/support/documentation/chemical-substances/faqs</rdfs:seeAlso>
        <skos:altLabel xml:lang="en">Chemical Abstracts Service Registry Number</skos:altLabel>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#EORI -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#EORI">
        <eudpp:identifierExampleValue>DE123456789012345</eudpp:identifierExampleValue>
        <eudpp:identifierMaxLength rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">17</eudpp:identifierMaxLength>
        <eudpp:identifierMinLength rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</eudpp:identifierMinLength>
        <rdfs:comment xml:lang="en">Economic Operators Registration and Identification (EU).
This is the EU’s official identifier for companies involved in import/export.
Mandatory for any company trading with the EU.

Used in customs declarations
Unique per company

Format: country code + number (e.g., DE123456789)

This is the most widely used identifier for economic operators in EU trade.</rdfs:comment>
        <rdfs:label xml:lang="en">EORI</rdfs:label>
        <rdfs:label>https://taxation-customs.ec.europa.eu/customs/customs-procedures-import-and-export/customs-operations/economic-operators-registration-and-identification-number-eori_en</rdfs:label>
        <skos:altLabel xml:lang="en">Economic Operators Registration and Identification (EU</skos:altLabel>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#GLN -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#GLN">
        <rdf:type rdf:resource="https://purl.org/eudpp#ActorIdentifierScheme"/>
        <eudpp:identifierExampleValue>9501101530003</eudpp:identifierExampleValue>
        <eudpp:identifierMaxLength rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">13</eudpp:identifierMaxLength>
        <eudpp:identifierMinLength rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">13</eudpp:identifierMinLength>
        <rdfs:comment xml:lang="en">A globally unique identifier defined by GS1 used to identify legal entities, functional entities, and physical locations within business and supply chain processes.

Typically identifies: legal entities, functional entities (departments), physical locations (warehouses, sites).</rdfs:comment>
        <rdfs:label xml:lang="en">GLN</rdfs:label>
        <rdfs:seeAlso>https://www.gs1.org/standards/id-keys/gln</rdfs:seeAlso>
        <skos:altLabel xml:lang="en">Global Location Number</skos:altLabel>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#GTIN -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#GTIN">
        <rdf:type rdf:resource="https://purl.org/eudpp#ProductIdentifierScheme"/>
        <eudpp:identifierExampleValue>14006381333938</eudpp:identifierExampleValue>
        <eudpp:identifierMaxLength rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">14</eudpp:identifierMaxLength>
        <eudpp:identifierMinLength rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</eudpp:identifierMinLength>
        <rdfs:comment xml:lang="en">A globally unique identifier for trade items, defined by GS1, used to identify products at various packaging levels.</rdfs:comment>
        <rdfs:label xml:lang="en">GTIN</rdfs:label>
        <rdfs:seeAlso>https://www.gs1.org/standards/id-keys/gtin</rdfs:seeAlso>
        <skos:altLabel xml:lang="en">Global Trade Item Number</skos:altLabel>
        <skos:definition xml:lang="en">A globally unique identifier for trade items, defined by GS1, used to identify products at various packaging levels.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#LEI -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#LEI">
        <rdf:type rdf:resource="https://purl.org/eudpp#ActorIdentifierScheme"/>
        <eudpp:identifierExampleValue>529900T8BM49AURSDO55</eudpp:identifierExampleValue>
        <eudpp:identifierMaxLength rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">20</eudpp:identifierMaxLength>
        <eudpp:identifierMinLength rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">20</eudpp:identifierMinLength>
        <rdfs:comment xml:lang="en">A Legal Entity Identifier (LEI) is a globally unique 20-character alphanumeric code that identifies legally distinct entities participating in financial transactions, as defined by ISO 17442.

A 20‑character code used globally for financial and regulatory reporting.
Required for companies involved in financial transactions.
Used by regulators, banks, customs, and some trade systems.</rdfs:comment>
        <rdfs:label xml:lang="en">LEI</rdfs:label>
        <rdfs:seeAlso>https://www.iso.org/standard/78829.html</rdfs:seeAlso>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#SKU -->

