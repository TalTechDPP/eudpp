    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#schemeAbbreviation">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#IdentifierScheme"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Abbreviation used for the scheme/standard</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#schemeReference -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#schemeReference">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#IdentifierScheme"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#anyURI"/>
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#string"/>
                </owl:unionOf>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:comment>schemeReference</rdfs:comment>
    </owl:DatatypeProperty>
    


