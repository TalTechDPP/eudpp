    <!-- https://purl.org/eudpp#hasScheme -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasScheme">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Identifier"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#IdentifierScheme"/>
        <rdfs:comment>The scheme/standard the Identifier follows</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp/#hasGranularity -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp/#hasGranularity">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Identifier"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp/#IdentifierGranularity"/>
        <rdfs:comment xml:lang="en">Defines the granularity of an identifier, if exists.</rdfs:comment>
    </owl:ObjectProperty>
    


