In case of dispute over Apache 2.0 applicability, or in case considering the ontology as a document, this ontology document is to be considered licensed under the Creative Commons Attribution 4.0 International (CC BY 4.0).</dcterms:licence>
        <dcterms:title xml:lang="en">The Identifier (IDENT) module of the EU DPP core ontology proposed by the CIRPASS-2 European project.</dcterms:title>
        <vann1:preferredNamespacePrefix>ident</vann1:preferredNamespacePrefix>
        <rdfs:comment xml:lang="en">First iteration of the Identifier module of the EU DPP core ontology proposal of the CIRPASS-2 European project.</rdfs:comment>
        <rdfs:label xml:lang="en">EU DPP IDENT</rdfs:label>
        <owl:versionInfo>1.0.1</owl:versionInfo>
    </owl:Ontology>
    


