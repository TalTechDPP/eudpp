#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( evt:AggregationEvent
                evt:AssociationEvent
                evt:ObjectEvent
                evt:TransactionEvent
                evt:TransformationEvent
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( evt:DPPArchivalEvent
                evt:DPPCreationEvent
                evt:DPPUpdateEvent
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( evt:InstanceIdentifier
                evt:Location
                evt:QuantityElement
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( evt:SourceOrDestination
                evt:SourceOrDestinationEntity
                evt:SourceOrDestinationType
              )
] .


