###  http://purl.org/eudpp#ADD
evt:ADD rdf:type owl:NamedIndividual ,
                 evt:ActionType ;
        rdfs:comment "Indicates that objects are being added to the context of the event, such as being commissioned or aggregated."@en ;
        rdfs:label "ADD"@en .


