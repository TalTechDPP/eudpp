#################################################################
#    Object Properties
#################################################################

###  https://purl.org/eudpp#accordingTo
<https://purl.org/eudpp#accordingTo> rdf:type owl:ObjectProperty ;
                                     rdfs:domain <https://purl.org/eudpp#ConformityCertificate> ;
                                     rdfs:range <https://purl.org/eudpp#ConformityAssessmentModule> ;
                                     dcterms:source """https://eur-lex.europa.eu/eli/dec/2008/768(1)/oj#art_4
Decision No 768/2008/EC Art 4"""@en ,
                                                    """https://eur-lex.europa.eu/eli/reg/2024/1781/oj/#art_43	
ESPR Art 43"""@en ;
                                     rdfs:comment "Property defining specifies conformity assess procedure/cerfication scheme underlying the cerfificate."@en ;
                                     rdfs:label "according to"@en .


###  https://purl.org/eudpp#allowsConformityAssessmentModule
<https://purl.org/eudpp#allowsConformityAssessmentModule> rdf:type owl:ObjectProperty ;
                                                          rdfs:domain <https://purl.org/eudpp#UnionHarmonisationLegislation> ;
                                                          rdfs:range <https://purl.org/eudpp#ConformityAssessmentModule> ;
                                                          dcterms:source """https://eur-lex.europa.eu/eli/dec/2008/768(1)/oj#art_4
Decision No 768/2008/EC Art 4"""@en ,
                                                                         """https://eur-lex.europa.eu/eli/reg/2024/1781/oj/#art_43
ESPR Art 43"""@en ;
                                                          rdfs:comment "A property that specifies the conformity assment procedure applicable to the type of product"@en ;
                                                          rdfs:label "allows Conformity Assessment Module"@en .


###  https://purl.org/eudpp#conformityDeclaredTo
<https://purl.org/eudpp#conformityDeclaredTo> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <https://purl.org/eudpp#EUDeclarationOfConformity> ;
                                              rdfs:range <https://purl.org/eudpp#UnionHarmonisationLegislation> ;
                                              dcterms:source "ESPR Annex V"@en ;
                                              rdfs:comment "A property which specifies which Union Harmonisation Legislation conformity is declared to."@en ;
                                              rdfs:label "conformity declared to"@en .


###  https://purl.org/eudpp#hasUnionHarmonisationLegislation
<https://purl.org/eudpp#hasUnionHarmonisationLegislation> rdf:type owl:ObjectProperty ;
                                                          rdfs:domain <https://purl.org/eudpp#EUDeclarationOfConformity> ;
                                                          rdfs:range <https://purl.org/eudpp#UnionHarmonisationLegislation> ;
                                                          dcterms:source "ESPR Annex V, (5)"@en ;
                                                          rdfs:comment "A property providing the Union Harmonisation Legislation refered to in the EU Declaration of Conformity."@en ;
                                                          rdfs:label "has Union Harmonisation Legislation"@en .


###  https://purl.org/eudpp#usedForPresumptionOfConformity
<https://purl.org/eudpp#usedForPresumptionOfConformity> rdf:type owl:ObjectProperty ;
                                                        rdfs:domain <https://purl.org/eudpp#ProductRequirement> ;
                                                        rdfs:range <https://purl.org/eudpp#UnionHarmonisationLegislation> ;
                                                        dcterms:source """https://eur-lex.europa.eu/eli/dec/2008/768(1)/oj#anx_I	
Decision No 768/2008/EC Annex I Art R8"""@en ,
                                                                       """https://eur-lex.europa.eu/eli/reg/2024/1781/oj/#art_41
ESPR Art 41"""@en ;
                                                        rdfs:comment "This property specifies which harmonised standards (or parts thereof) was used to assess conformity with the Union harmonistation legislation."@en ;
                                                        rdfs:label "used for presumtion of conformity"@en .


#################################################################
#    Data properties
#################################################################

###  https://purl.org/eudpp#assignedELI
<https://purl.org/eudpp#assignedELI> rdf:type owl:DatatypeProperty ;
                                     rdfs:domain <https://purl.org/eudpp#UnionHarmonisationLegislation> ;
                                     rdfs:range xsd:anyURI ;
                                     dcterms:source "https://eur-lex.europa.eu/eli-register/what_is_eli.html"@en ;
                                     rdfs:comment "Standardised identification that makes it easier to identify and describe legislation across Europe."@en ;
                                     rdfs:label "assigned ELI"@en .


###  https://purl.org/eudpp#certificateNumber
<https://purl.org/eudpp#certificateNumber> rdf:type owl:DatatypeProperty ;
                                           rdfs:domain <https://purl.org/eudpp#ConformityCertificate> ;
                                           rdfs:range xsd:string ;
                                           dcterms:source "certificate number"@en ;
                                           rdfs:comment "Number of the certificate" .


###  https://purl.org/eudpp#certificateRevisionNumber
<https://purl.org/eudpp#certificateRevisionNumber> rdf:type owl:DatatypeProperty ;
                                                   rdfs:domain <https://purl.org/eudpp#ConformityCertificate> ;
                                                   rdfs:range xsd:string ;
                                                   rdfs:comment "Number of the revision of a certificate" ;
                                                   rdfs:label "certificate revision number"@en .


#################################################################
#    Classes
#################################################################

###  https://purl.org/eudpp#CommonSpecification
<https://purl.org/eudpp#CommonSpecification> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://purl.org/eudpp#TechnicalSpecification> ;
                                             dcterms:source "ESPR Art 42, https://eur-lex.europa.eu/eli/reg/2024/1781/oj#art_42"@en ;
                                             rdfs:comment "Common specification means ecodesign requirements, essential requirements for digital product passports or test, measurement or calculation methods established by implementing acts adopted by the Commission for products covered by delegated acts pursuant to ESPR Article 4."@en ;
                                             rdfs:label "Common Specification"@en .


###  https://purl.org/eudpp#ConformityAssessmentModule
<https://purl.org/eudpp#ConformityAssessmentModule> rdf:type owl:Class ;
                                                    dcterms:source "Decision No 768/2008/EC Art 4, https://eur-lex.europa.eu/eli/dec/2008/768(1)/oj#art_4"@en ,
                                                                   "ESPR Art 43, https://eur-lex.europa.eu/eli/reg/2024/1781/oj/#art_43"@en ;
                                                    rdfs:comment "Conformity Assessment module means the possible conformity assessment elements that can be chosen, in accordance with certain criteria, to fullfill the conformity accessement required to be performed by Community harmonisation legislation in respect of a particular product."@en ;
                                                    rdfs:label "Conformity Assessment Module"@en .


###  https://purl.org/eudpp#ConformityCertificate
<https://purl.org/eudpp#ConformityCertificate> rdf:type owl:Class ;
                                               dcterms:source "Commission notice The ‘Blue Guide’ on the implementation of EU product rules 2022 Annex 4, https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=oj:JOC_2022_247_R_0001"@en ,
                                                              "ESPR Annex III (e)"@en ;
                                               rdfs:comment "Conformity assessment certificate for a certification. The blue guide uses the term \"cerficate of conformity\". The ESPR uses \"conformity certificate\" as well as \"certificate\" and \"approval decision\"."@en ;
                                               rdfs:label "Conformity Certificate"@en .


###  https://purl.org/eudpp#EUDeclarationOfConformity
<https://purl.org/eudpp#EUDeclarationOfConformity> rdf:type owl:Class ;
                                                   rdfs:subClassOf owl:Thing ;
                                                   dcterms:source "Decision No 768/2008/EC Annex I Art R10, https://eur-lex.europa.eu/eli/dec/2008/768(1)/oj#anx_I"@en ,
                                                                  "ESPR Art 44, https://eur-lex.europa.eu/eli/reg/2024/1781/oj/#art_44"@en ;
                                                   rdfs:comment "The EU Declaration of Conformity shall state that the fulfilment of the ecodesign requirements specified in the applicable delegated acts adopted pursuant to ESPR Article 4 has been demonstrated or that a presumption of conformity applies in accordance with ESPR Article 41."@en ;
                                                   rdfs:label "EU Declaration of Conformity"@en .


###  https://purl.org/eudpp#HarmonisedStandard
<https://purl.org/eudpp#HarmonisedStandard> rdf:type owl:Class ;
                                            rdfs:subClassOf <https://purl.org/eudpp#ProductRequirement> ;
                                            dcterms:source "Regulation (EU) No 1025/2012 Art 2 (1c), https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=celex%3A32012R1025#art_2"@en ;
                                            rdfs:comment "Harmonised Standard means a European standard adopted on the basis of a request made by the Commission for the application of Union harmonisation legislation."@en ;
                                            rdfs:label "Harmonised Standard"@en .


###  https://purl.org/eudpp#OtherTechnicalSpecification
<https://purl.org/eudpp#OtherTechnicalSpecification> rdf:type owl:Class ;
                                                     rdfs:subClassOf <https://purl.org/eudpp#TechnicalSpecification> ;
                                                     dcterms:source "ESPR Annex V, (6)"@en ;
                                                     rdfs:comment "Other technical specifications in relation to which conformity is declared."@en ;
                                                     rdfs:label "Other Technical Specification"@en .


###  https://purl.org/eudpp#ProductRequirement
<https://purl.org/eudpp#ProductRequirement> rdf:type owl:Class ;
                                            rdfs:comment "Product requirements means a requirement to be fullfilled by a product when placed on the market."@en ;
                                            rdfs:label "Product Requirement"@en .


###  https://purl.org/eudpp#TechnicalSpecification
<https://purl.org/eudpp#TechnicalSpecification> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://purl.org/eudpp#ProductRequirement> ;
                                                dcterms:source """Regulation (EU) No 1025/2012 Art 2 (4)
https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=celex%3A32012R1025#art_2"""@en ;
                                                rdfs:comment "Technical specification means a document that prescribes technical requirements to be fulfilled by a product, process, service or system and which lays down one or more of the following: Common Specification or Other Technical Specification."@en ;
                                                rdfs:label "Technical Specification"@en .


###  https://purl.org/eudpp#UnionHarmonisationLegislation
<https://purl.org/eudpp#UnionHarmonisationLegislation> rdf:type owl:Class ;
                                                       dcterms:source """Decision No 768/2008/EC Annex I Art R1 (17)
https://eur-lex.europa.eu/eli/dec/2008/768(1)/oj#anx_I"""@en ;
                                                       rdfs:comment "Union Harmonisation Legislation shall mean any Union legislation harmonising the conditions for the marketing of products. Examples are directives, regulations and delegated acts."@en ;
                                                       rdfs:label "Union Harmonised Legislation"@en .


