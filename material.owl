    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2001/XMLSchema#date -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://purl.org/eudpp#hasMaterialType -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasMaterialType">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#MaterialOfComposition"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#MaterialType"/>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp/#hasMaterialOrigin -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp/#hasMaterialOrigin">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#MaterialOfComposition"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#MaterialOrigin"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://purl.org/eudpp#isCriticalRawMaterial -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#isCriticalRawMaterial">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#MaterialOfComposition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <dcterms:references xml:lang="en">[ESPR Annex I h)]</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Product parameters: use or content of recycled materials and recovery of materials, including critical raw materials; [ESPR Annex I h)]</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#materialIdentifier -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#materialIdentifier">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#MaterialOfComposition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dcterms:references xml:lang="en">ESPR Annex I c)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Product parameters: identification of  ... materials [ESPR Annex I c)]</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#materialIdentifierScheme -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#materialIdentifierScheme">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#MaterialOfComposition"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#anyURI"/>
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#string"/>
                </owl:unionOf>
            </rdfs:Datatype>
        </rdfs:range>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#materialIsRecyclable -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#materialIsRecyclable">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#MaterialOfComposition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <dcterms:references xml:lang="en">ESPR Art 5 (1n), Annex I d)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Product parameters: design for recycling, ease and quality of recycling as expressed through use of easily recyclable materials [ESPR Art 5 (1n), Annex I d)]</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#materialIsSustainableRenewable -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#materialIsSustainableRenewable">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#MaterialOfComposition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <dcterms:references xml:lang="en">ESPR Annex I i)</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Product parameters: use or content of sustainable renewable materials; [ESPR Annex I i)]</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#materialPercentage -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#materialPercentage">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#MaterialOfComposition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">Material percentage in a Product, e.g., mass fraction (percentage by weight).</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp/#materialComponent -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp/#materialComponent">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#MaterialOfComposition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The specific part of the Product this material belongs to. Description. 
For example, in case of a textile product: [Main, Lining, Filling].</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp/#materialRecycledContent -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp/#materialRecycledContent">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#MaterialOfComposition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Percentage of recycled content</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://purl.org/eudpp#MaterialOfComposition -->

    <owl:Class rdf:about="https://purl.org/eudpp#MaterialOfComposition">
        <rdfs:comment xml:lang="en">Material the product (or component) is made of [ESPR Annex I]. Material as an element of composition.</rdfs:comment>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#MaterialOrigin -->

    <owl:Class rdf:about="https://purl.org/eudpp#MaterialOrigin">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://purl.org/eudpp#raw"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#recycled"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#renewable"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <dcterms:references xml:lang="en">[ESPR Annex I]</dcterms:references>
        <dcterms:source>https://eur-lex.europa.eu/eli/reg/2024/1781/oj</dcterms:source>
        <rdfs:comment xml:lang="en">Origin of the material used in product [ESPR Annex I]</rdfs:comment>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#MaterialType -->

    <owl:Class rdf:about="https://purl.org/eudpp#MaterialType">
        <rdfs:comment xml:lang="en">Placeholder class for material type classification applicable in a sector or mandated by a delegated act (DA).

Potential types could be, on the example of textile sector: cotton, nylon, ...</rdfs:comment>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://purl.org/eudpp#raw -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#raw">
        <rdf:type rdf:resource="https://purl.org/eudpp#MaterialOrigin"/>
        <rdfs:comment>Raw material</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#recycled -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#recycled">
        <rdf:type rdf:resource="https://purl.org/eudpp#MaterialOrigin"/>
        <rdfs:comment>Recycled material</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#renewable -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#renewable">
        <rdf:type rdf:resource="https://purl.org/eudpp#MaterialOrigin"/>
        <rdfs:comment>Renewable material</rdfs:comment>
    </owl:NamedIndividual>
</rdf:RDF>



