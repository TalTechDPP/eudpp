        <rdf:type rdf:resource="https://purl.org/eudpp#LCIAImpactIndicator"/>
        <rdfs:comment xml:lang="en">Radiative forcing as global warming potential, GWP100, expressed in kg CO2-equivalent. Aggregate of climate-change effects from fossil, biogenic and land-use-and-land-use-change sources. EF 3.1 / PEF impact category. Colloquially known as the carbon footprint of the product. JRC characterisation factors per EUR 31414 EN (2023).</rdfs:comment>
        <rdfs:label xml:lang="en">Climate change</rdfs:label>
        <skos:altLabel xml:lang="en">Carbon footprint</skos:altLabel>
        <skos:altLabel xml:lang="en">Climate change</skos:altLabel>
        <ilcdSource>LCA ontology extension</ilcdSource>
        <unitAsString xml:lang="en">kg CO2-eq</unitAsString>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#ind_EF_ecotoxicityFreshwater -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#ind_EF_ecotoxicityFreshwater">
        <rdf:type rdf:resource="https://purl.org/eudpp#LCIAImpactIndicator"/>
        <rdfs:comment xml:lang="en">Comparative toxic unit for ecosystems (freshwater), in CTUe. EF 3.1 / PEF impact category.</rdfs:comment>
        <rdfs:label xml:lang="en">Ecotoxicity, freshwater</rdfs:label>
        <skos:altLabel xml:lang="en">Ecotoxicity, freshwater</skos:altLabel>
        <ilcdSource>LCA ontology extension</ilcdSource>
        <unitAsString xml:lang="en">CTUe</unitAsString>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/eudpp#ind_EF_eutrophicationFreshwater -->

    <owl:NamedIndividual rdf:about="https://purl.org/eudpp#ind_EF_eutrophicationFreshwater">
        <rdf:type rdf:resource="https://purl.org/eudpp#LCIAImpactIndicator"/>
