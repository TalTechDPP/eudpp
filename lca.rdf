    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2001/XMLSchema#date -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#gYear -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#gYear"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://purl.org/eudpp#areaOfProtection -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#areaOfProtection">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCIAImpactCategory"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#AreaOfProtection"/>
        <rdfs:comment xml:lang="en">Area-of-protection addressed by an LCIAImpactCategory (1..n cardinality: a single impact category can address several Areas of Protection — for example, ozone depletion affects both Natural Environment and Human Health). Domain moved in v1.9.7 from LCIAOrInventoryMethod to LCIAImpactCategory: ontologically AoP is a property of the impact category, not of the calculator that addresses it; different methods for the same impact category share the same AoPs. This deviates from the ILCD serialisation pattern (which puts areaOfProtection on LCIAMethodDataSet) for ontological correctness; the ILCD value can still be derived by following impactCategory then areaOfProtection.</rdfs:comment>
        <rdfs:label xml:lang="en">area of protection</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#complianceStatus -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#complianceStatus">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#ComplianceDeclaration"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#ComplianceStatus"/>
        <rdfs:comment xml:lang="en">Level of compliance declared by a ComplianceDeclaration (fully compliant, partially compliant, or not compliant).</rdfs:comment>
        <rdfs:label xml:lang="en">compliance status</rdfs:label>
        <ilcdSource>LCA ontology extension</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#declaresManufacturerRecord -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#declaresManufacturerRecord">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCAStudy"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#ManufacturerRecord"/>
        <rdfs:comment xml:lang="en">Link from an LCAStudy (or its subclass EPDStudy) to a ManufacturerRecord. An LCA or EPD study frequently covers a product range or sector average drawing primary data from several manufacturers; this property associates the study with each contributing manufacturer record. Distinct from the Connector property eudpp:hasManufacturer (Product -&gt; Actor), which identifies the single manufacturer of a specific DPP-bearing product instance. Corresponds to ILCD+EPD element epd24:manufacturers/epd24:manufacturer. Domain widened in v1.9.7 from EPDStudy to LCAStudy so that any LCA study can declare its contributing manufacturers.</rdfs:comment>
        <rdfs:label xml:lang="en">declares manufacturer record</rdfs:label>
        <ilcdSource>ILCD+EPD extension</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#en15804Group -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#en15804Group">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#EN15804Indicator"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#EN15804IndicatorGroup"/>
        <rdfs:comment xml:lang="en">Link from an EN15804Indicator individual to the indicator group it belongs to (core impact, with-caveats, resource use, waste, valorisation, exported energy). Object property; range is eudpp:EN15804IndicatorGroup.</rdfs:comment>
        <rdfs:label xml:lang="en">EN 15804 indicator group</rdfs:label>
        <ilcdSource>LCA ontology extension</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#forIndicator -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#forIndicator">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCIAOrInventoryMethod"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#LCIAIndicator"/>
        <rdfs:comment xml:lang="en">Link from an LCIAOrInventoryMethod to the LCIAIndicator individual that it computes (typically an EN15804Indicator individual; for non-EN-15804 LCA studies, any LCIAIndicator individual). This is the key identity of an ILCD+EPD LCIA Method Data Set. Cardinality is at most 1 per method instance (enforced via owl:Restriction on LCIAOrInventoryMethod). Range generalised in v1.9.7 from EN15804Indicator to LCIAIndicator so non-EN-15804 indicators can be referenced.</rdfs:comment>
        <rdfs:label xml:lang="en">for indicator</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#forLCIAOrInventoryMethod -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#forLCIAOrInventoryMethod">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCAResult"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#LCIAOrInventoryMethod"/>
        <rdfs:comment xml:lang="en">Link from an LCAResult (LCIAResult or InventoryIndicatorResult) to the LCIAOrInventoryMethod used to compute it. Corresponds to ILCD+EPD element LCIAResult/referenceToLCIAMethodDataSet. Renamed in v1.9.7 from v1.9.6&apos;s forLCIAMethod to align with the renamed method class.</rdfs:comment>
        <rdfs:label xml:lang="en">for LCIA or Inventory method</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#forModule -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#forModule">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCIAModuleValue"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#LifeCycleModule"/>
        <rdfs:comment xml:lang="en">Link from an LCIAModuleValue to the EN 15804+A2 life-cycle module it refers to. Corresponds to ILCD+EPD attribute @epd:module on epd:amount.</rdfs:comment>
        <rdfs:label xml:lang="en">for life-cycle module</rdfs:label>
        <ilcdSource>ILCD+EPD extension</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasComplianceDeclaration -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasComplianceDeclaration">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCAStudy"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#ComplianceDeclaration"/>
        <rdfs:comment xml:lang="en">Link from an LCAStudy (or its subclass EPDStudy) to a ComplianceDeclaration. Compliance can be declared against any standard relevant to the study type (ISO 14040/14044, ISO 14025, ISO 14067, ISO 21930, EN 15804+A2, PEFCR-specific rules, etc.). Corresponds to ILCD+EPD element complianceDeclarations/compliance. Domain widened in v1.9.7 from EPDStudy to LCAStudy.</rdfs:comment>
        <rdfs:label xml:lang="en">has compliance declaration</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasExternalDocumentation -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasExternalDocumentation">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCAStudy"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Source"/>
        <rdfs:comment xml:lang="en">Link from an LCAStudy to a background document (e.g. an LCA project report, safety data sheet, or explanatory material). Corresponds to ILCD+EPD element referenceToExternalDocumentation on dataSetInformation.</rdfs:comment>
        <rdfs:label xml:lang="en">has external documentation</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasImpactModel -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasImpactModel">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCIAOrInventoryMethod"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#ImpactModel"/>
        <rdfs:comment xml:lang="en">Link from an LCIAOrInventoryMethod to its characterisation-model block (where applicable; inventory-only methods may not have one). Corresponds to ILCD+EPD element impactModel on LCIAMethodDataSet.</rdfs:comment>
        <rdfs:label xml:lang="en">has impact model</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasInventoryIndicatorResult -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasInventoryIndicatorResult">
        <rdfs:subPropertyOf rdf:resource="https://purl.org/eudpp#hasLCAResult"/>
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCAStudy"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#InventoryIndicatorResult"/>
        <rdfs:comment xml:lang="en">Link from an LCAStudy (or its subclass EPDStudy) to one of its aggregated inventory-indicator results. Sub-property of eudpp:hasLCAResult; range narrowed to eudpp:InventoryIndicatorResult. Corresponds to ILCD+EPD element LCIAResults/LCIAResult when the indicator is an EN 15804+A2 inventory indicator (resource use, waste, output flows). Renamed in v1.9.7 from v1.9.6&apos;s hasInventoryResult (the previous name was ambiguous with raw life-cycle inventory; this property addresses aggregated indicator-level inventory results).</rdfs:comment>
        <rdfs:label xml:lang="en">has inventory indicator result</rdfs:label>
        <ilcdSource>ILCD+EPD extension</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasLCAResult -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasLCAResult">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCAStudy"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#LCAResult"/>
        <rdfs:comment xml:lang="en">Link from an LCAStudy (or its subclass EPDStudy) to one of its LCA results. Range is the abstract eudpp:LCAResult; sub-properties eudpp:hasLCIAResult and eudpp:hasInventoryResult narrow the result to the corresponding sibling subclass. Querying for eudpp:hasLCAResult retrieves both kinds of results in one go.</rdfs:comment>
        <rdfs:label xml:lang="en">has LCA result</rdfs:label>
        <ilcdSource>LCA ontology extension</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasLCIAResult -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasLCIAResult">
        <rdfs:subPropertyOf rdf:resource="https://purl.org/eudpp#hasLCAResult"/>
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCAStudy"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#LCIAResult"/>
        <rdfs:comment xml:lang="en">Link from an LCAStudy (or its subclass EPDStudy) to one of its characterised impact results. Sub-property of eudpp:hasLCAResult; range narrowed to eudpp:LCIAResult. Corresponds to ILCD+EPD element LCIAResults/LCIAResult when the indicator is an EN 15804+A2 impact indicator.</rdfs:comment>
        <rdfs:label xml:lang="en">has LCIA result</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasModuleValue -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasModuleValue">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCAResult"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#LCIAModuleValue"/>
        <rdfs:comment xml:lang="en">Link from an LCAResult (LCIAResult or InventoryIndicatorResult) to one of its per-module (and optionally per-scenario) numerical values. Corresponds to ILCD+EPD element LCIAResult/other/epd:amount.</rdfs:comment>
        <rdfs:label xml:lang="en">has module value</rdfs:label>
        <ilcdSource>ILCD+EPD extension</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasReview -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasReview">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCAStudy"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Review"/>
        <rdfs:comment xml:lang="en">Link from an LCAStudy to a critical-review / verification record. Corresponds to ILCD+EPD element validation/review.</rdfs:comment>
        <rdfs:label xml:lang="en">has review</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#hasUnit -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#hasUnit">
        <rdfs:range rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/Unit"/>
        <rdfs:comment xml:lang="en">Link from an LCIAModuleValue (or LCIAOrInventoryMethod) to the unit (OM-2 Unit individual) in which the value is expressed. Corresponds to ILCD+EPD element referenceToUnitGroupDataSet. Range is the externally-defined om-2:Unit class. Replaces v1.9.4&apos;s xsd:string-typed eudpp:hasUnit.</rdfs:comment>
        <rdfs:label xml:lang="en">has unit</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#impactCategory -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#impactCategory">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCIAOrInventoryMethod"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#LCIAImpactCategory"/>
        <rdfs:comment xml:lang="en">Impact category addressed by the LCIAOrInventoryMethod. Corresponds to ILCD+EPD element impactCategory on LCIAMethodDataSet.</rdfs:comment>
        <rdfs:label xml:lang="en">impact category</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#licenseType -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#licenseType">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCAStudy"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#LicenseType"/>
        <rdfs:comment xml:lang="en">License applicable to the LCA / EPD study. Corresponds to ILCD+EPD element publicationAndOwnership/licenseType.</rdfs:comment>
        <rdfs:label xml:lang="en">license type</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#methodology -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#methodology">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCIAOrInventoryMethod"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#LCIAMethodology"/>
        <rdfs:comment xml:lang="en">Link from an LCIAOrInventoryMethod to one or several LCIAMethodology individuals it belongs to (e.g. eudpp:methodology_EF3_1). Cardinality 1..n: a single method can be classified into more than one methodology (for example, when two methodologies share the same characterisation factors for one indicator). Replaces the free-text methodology name from v1.9.4 in order to allow structured queries.</rdfs:comment>
        <rdfs:label xml:lang="en">methodology</rdfs:label>
        <ilcdSource>LCA ontology extension</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#referenceToBackgroundDatabase -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#referenceToBackgroundDatabase">
        <rdfs:subPropertyOf rdf:resource="https://purl.org/eudpp#referenceToDataSource"/>
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCAStudy"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#BackgroundDatabase"/>
        <rdfs:comment xml:lang="en">Link from an LCAStudy to a background LCI database used for the modelling (1..n). Sub-property of eudpp:referenceToDataSource: a background database is a kind of data source, but instances using this more specific property let consumers filter for database-typed sources. NEW in v1.9.7.</rdfs:comment>
        <rdfs:label xml:lang="en">reference to background database</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#referenceToCompleteReviewReport -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#referenceToCompleteReviewReport">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Review"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#ReviewReport"/>
        <rdfs:comment xml:lang="en">Link from a Review to the full review report. Corresponds to ILCD+EPD element review/referenceToCompleteReviewReport.</rdfs:comment>
        <rdfs:label xml:lang="en">reference to complete review report</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#referenceToComplianceSystem -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#referenceToComplianceSystem">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#ComplianceDeclaration"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#ComplianceSystem"/>
        <rdfs:comment xml:lang="en">Link from a ComplianceDeclaration to the standard or programme it references (EN 15804+A2, ISO 14025, ISO 21930, etc.). Corresponds to ILCD+EPD element compliance/referenceToComplianceSystem.</rdfs:comment>
        <rdfs:label xml:lang="en">reference to compliance system</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#referenceToDataSource -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#referenceToDataSource">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCAStudy"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Source"/>
        <rdfs:comment xml:lang="en">Link from an LCAStudy to the background database(s) or literature source(s) used for modelling. Corresponds to ILCD+EPD element referenceToDataSource (e.g. ecoinvent, GaBi/Sphera, Okobaudat).</rdfs:comment>
        <rdfs:label xml:lang="en">reference to data source</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#referenceToExternalDocumentation_LCIAOrInventoryMethod -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#referenceToExternalDocumentation_LCIAOrInventoryMethod">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCIAOrInventoryMethod"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Source"/>
        <rdfs:comment xml:lang="en">Link from an LCIAOrInventoryMethod to the external documentation describing the method. Corresponds to ILCD+EPD element referenceToExternalDocumentation on LCIAMethodDataSet/dataSetInformation. Separate from the property eudpp:hasExternalDocumentation which has domain eudpp:LCAStudy. Renamed in v1.9.7 from v1.9.6&apos;s referenceToExternalDocumentation_LCIAMethod.</rdfs:comment>
        <rdfs:label xml:lang="en">reference to external documentation (on LCIA or Inventory method)</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#referenceToIncludedMethods -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#referenceToIncludedMethods">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCIAOrInventoryMethod"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#LCIAOrInventoryMethod"/>
        <rdfs:comment xml:lang="en">Link from a methodology-level LCIAOrInventoryMethod (a collection of methods sharing a methodology such as &quot;EF 3.1&quot;) to each of the individual-indicator method instances it aggregates. ILCD+EPD LCIA Method Data Sets can represent either a single LCIA or inventory method (one indicator) or a methodology (a collection/list of methods); this property is used only in the latter case. Corresponds to ILCD+EPD element referenceToIncludedMethods.</rdfs:comment>
        <rdfs:label xml:lang="en">reference to included methods</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#referenceToLCIAMethodReport -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#referenceToLCIAMethodReport">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCIAOrInventoryMethod"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#LCIAMethodReport"/>
        <rdfs:comment xml:lang="en">Link from an LCIAOrInventoryMethod to the formal LCIA method report (e.g. the EF 3.1 method description). Specialisation of the more generic eudpp:referenceToExternalDocumentation_LCIAOrInventoryMethod when the documentation is specifically a method-report-typed Source. NEW in v1.9.7.</rdfs:comment>
        <rdfs:label xml:lang="en">reference to LCIA method report</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#referenceToModelSource -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#referenceToModelSource">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#ImpactModel"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#Source"/>
        <rdfs:comment xml:lang="en">Link from an ImpactModel to the bibliographic source(s) describing the characterisation model. Corresponds to ILCD+EPD element referenceToModelSource. Range is eudpp:Source; tighter semantic linking to eudpp:LCIAMethodReport is intended to be enforced via SHACL in a later release.</rdfs:comment>
        <rdfs:label xml:lang="en">reference to model source</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#referenceToOriginalEPD -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#referenceToOriginalEPD">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#EPDStudy"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#EPDDocument"/>
        <rdfs:comment xml:lang="en">Link from the machine-readable EPDStudy to the published EPD document (typically PDF). Corresponds to ILCD+EPD element epd2:referenceToOriginalEPD.</rdfs:comment>
        <rdfs:label xml:lang="en">reference to original EPD</rdfs:label>
        <ilcdSource>ILCD+EPD extension</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#referenceToPCR -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#referenceToPCR">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#EPDStudy"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#PCR"/>
        <rdfs:comment xml:lang="en">Link from an EPDStudy to the Product Category Rules document(s) it follows (1..n). Corresponds to ILCD+EPD element referenceToPCR. NEW in v1.9.7.</rdfs:comment>
        <rdfs:label xml:lang="en">reference to PCR</rdfs:label>
        <ilcdSource>ILCD+EPD extension</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#referenceToPEFCR -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#referenceToPEFCR">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCAStudy"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#PEFCR"/>
        <rdfs:comment xml:lang="en">Link from an LCAStudy to a Product Environmental Footprint Category Rules document (1..n). Parallel to referenceToPCR but for PEF studies. NEW in v1.9.7.</rdfs:comment>
        <rdfs:label xml:lang="en">reference to PEFCR</rdfs:label>
        <ilcdSource>LCA ontology extension</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- https://purl.org/eudpp#typeOfReview -->

    <owl:ObjectProperty rdf:about="https://purl.org/eudpp#typeOfReview">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Review"/>
        <rdfs:range rdf:resource="https://purl.org/eudpp#TypeOfReview"/>
        <rdfs:comment xml:lang="en">The kind of review performed (independent external, accredited third party, etc.). Corresponds to ILCD+EPD attribute review/@type.</rdfs:comment>
        <rdfs:label xml:lang="en">type of review</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://purl.org/eudpp#accessRestrictions -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#accessRestrictions">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCAStudy"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">Human-readable description of access and use restrictions for the LCA / EPD study (equivalent to dcterms:accessRights). Corresponds to ILCD+EPD element accessRestrictions.</rdfs:comment>
        <rdfs:label xml:lang="en">access restrictions</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#amount -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#amount">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCIAModuleValue"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Numerical value of an LCIAModuleValue, in the unit given by the associated LCIAMethod. Corresponds to ILCD+EPD text content of epd:amount inside LCIAResult/other.</rdfs:comment>
        <rdfs:label xml:lang="en">amount</rdfs:label>
        <ilcdSource>ILCD+EPD extension</ilcdSource>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#baseName -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#baseName">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCAStudy"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"/>
        <rdfs:comment xml:lang="en">General descriptive name of the product or system represented by the study. Multilingual. Corresponds to ILCD+EPD element processInformation/dataSetInformation/name/baseName.</rdfs:comment>
        <rdfs:label xml:lang="en">base name</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#dataSetVersion -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#dataSetVersion">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCAStudy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Version number of this LCA / EPD study instance, independent of the ontology version. Format: major.minor.sub-minor (e.g. &quot;02.00.011&quot;). Corresponds to ILCD+EPD element publicationAndOwnership/dataSetVersion.</rdfs:comment>
        <rdfs:label xml:lang="en">data set version</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#epdFormatVersion -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#epdFormatVersion">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#EPDStudy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Version tag of the ILCD+EPD format used (e.g. &quot;1.3&quot;). Corresponds to ILCD+EPD attribute @epd2:epd-version on processDataSet. Renamed in v1.9.7 from v1.9.6&apos;s epdExtensionVersion (clearer wording — and parallel to eudpp:ilcdFormatVersion on LCAStudy).</rdfs:comment>
        <rdfs:label xml:lang="en">EPD format version</rdfs:label>
        <ilcdSource>ILCD+EPD extension</ilcdSource>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#expiryDate -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#expiryDate">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#EPDStudy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date on which the EPD&apos;s validity expires. EN 15804+A2 EPDs are typically valid for five years from publication. Corresponds to ILCD+EPD element epd2:expirationDateOfEPD on time/other. Domain restricted in v1.9.7 from LCAStudy to EPDStudy: a generic LCA study does not have a regulated expiry; only EPDs do.</rdfs:comment>
        <rdfs:label xml:lang="en">expiry date</rdfs:label>
        <ilcdSource>ILCD+EPD extension</ilcdSource>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#forScenario -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#forScenario">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCIAModuleValue"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Identifier of the scenario this LCIAModuleValue applies to (free-text label matching the EPD&apos;s scenario declaration). Corresponds to ILCD+EPD attribute @epd:scenario on epd:amount. No separate Scenario class is defined in this release; scenario descriptions, when needed, can be carried on the EPD document. A future release may introduce a Scenario class with rdfs:label for stronger validation.</rdfs:comment>
        <rdfs:label xml:lang="en">for scenario</rdfs:label>
        <ilcdSource>ILCD+EPD extension</ilcdSource>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#hasCopyright -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#hasCopyright">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCAStudy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">True if a copyright applies to the LCA / EPD study, false otherwise. Corresponds to ILCD+EPD element publicationAndOwnership/copyright. Modelled as xsd:boolean per the ILCD+EPD schema definition (two-valued).</rdfs:comment>
        <rdfs:label xml:lang="en">has copyright</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#ilcdFormatVersion -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#ilcdFormatVersion">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCAStudy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">ILCD schema version used by the source serialisation of this study (e.g. &apos;1.1&apos;). Corresponds to ILCD+EPD attribute @version on processDataSet.</rdfs:comment>
        <rdfs:label xml:lang="en">ILCD format version</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#impactIndicatorDescription -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#impactIndicatorDescription">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCIAOrInventoryMethod"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Human-readable description of the indicator&apos;s meaning (what it measures, how to interpret). Corresponds to ILCD+EPD element impactIndicator on LCIAMethodDataSet.</rdfs:comment>
        <rdfs:label xml:lang="en">impact indicator description</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#isDeclared -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#isDeclared">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCIAModuleValue"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">True if this module value is declared in the study (has a numerical amount), false if the module is explicitly marked as not declared (ND / MND) for this indicator/scenario. Absence of the LCIAModuleValue triple altogether means the module was not in scope of the study (MNA - module not applicable).</rdfs:comment>
        <rdfs:label xml:lang="en">is declared</rdfs:label>
        <ilcdSource>LCA ontology extension</ilcdSource>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#lciaOrInventoryMethodVersion -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#lciaOrInventoryMethodVersion">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCIAOrInventoryMethod"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Version of the specific LCIA or Inventory method instance (where applicable). Captures method-instance-level versioning, distinct from methodology-level versioning (eudpp:methodologyVersion on LCIAMethodology). Replaces v1.9.6&apos;s efVersion in v1.9.7: EF version is already covered indirectly via the compliance declaration&apos;s reference to the appropriate compliance system, while a generic per-method version field is needed.</rdfs:comment>
        <rdfs:label xml:lang="en">LCIA or Inventory method version</rdfs:label>
        <ilcdSource>LCA ontology extension</ilcdSource>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#methodologyVersion -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#methodologyVersion">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCIAMethodology"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Version identifier of an LCIAMethodology individual (e.g. &quot;3.1&quot; for EF 3.1, &quot;2002&quot; for CML 2002).</rdfs:comment>
        <rdfs:label xml:lang="en">methodology version</rdfs:label>
        <ilcdSource>LCA ontology extension</ilcdSource>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#modelName -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#modelName">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#ImpactModel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Name of the characterisation model used (e.g. &quot;IPCC AR6&quot; for GWP). Corresponds to ILCD+EPD element modelName on impactModel.</rdfs:comment>
        <rdfs:label xml:lang="en">model name</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#modelVersion -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#modelVersion">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#ImpactModel"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Version of the characterisation model used (e.g. &quot;IPCC AR6 2021&quot; vs &quot;IPCC AR5 2013&quot;, which give different GWP100 values).</rdfs:comment>
        <rdfs:label xml:lang="en">model version</rdfs:label>
        <ilcdSource>LCA ontology extension</ilcdSource>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#referenceYear -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#referenceYear">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCAStudy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
        <rdfs:comment xml:lang="en">Start year of the time period for which the study is valid. Corresponds to ILCD+EPD element time/referenceYear on processDataSet.</rdfs:comment>
        <rdfs:label xml:lang="en">reference year</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#registrationNumber -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#registrationNumber">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#EPDStudy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Identifying number issued by the EPD programme operator (typically visible on the EPD document). Distinct from the dataset UUID. Corresponds to ILCD+EPD element publicationAndOwnership/registrationNumber.</rdfs:comment>
        <rdfs:label xml:lang="en">registration number</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#reviewDate -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#reviewDate">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#Review"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date on which the review was completed. Important for DPP consumers to assess whether the review is still current.</rdfs:comment>
        <rdfs:label xml:lang="en">review date</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/eudpp#uuid -->

    <owl:DatatypeProperty rdf:about="https://purl.org/eudpp#uuid">
        <rdfs:domain rdf:resource="https://purl.org/eudpp#LCAStudy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The Universally Unique Identifier of this LCA / EPD study, as mandated by ILCD+EPD as the primary persistent identifier. Once a study is created and a UUID is generated, the UUID stays the same forever; any change increments eudpp:dataSetVersion. String formatted as an RFC 4122 UUID (36 characters, hyphenated).</rdfs:comment>
        <rdfs:label xml:lang="en">UUID</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.ontology-of-units-of-measure.org/resource/om-2/Unit -->

    <owl:Class rdf:about="http://www.ontology-of-units-of-measure.org/resource/om-2/Unit">
        <rdfs:comment xml:lang="en">Externally defined class imported by reference from OM-2 (Ontology of Units of Measure). Used as the range of eudpp:hasUnit. OM-2 is not imported via owl:imports to avoid transitive closure of a large external ontology; implementers needing unit-based reasoning should load OM-2 separately alongside this ontology.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/"/>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#AreaOfProtection -->

    <owl:Class rdf:about="https://purl.org/eudpp#AreaOfProtection">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://purl.org/eudpp#aopHumanHealth"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#aopManMadeEnvironment"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#aopNaturalEnvironment"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#aopNaturalResources"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#aopOther"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">Damage area addressed by an LCIA method (only used for damage/end-point methods). Enumeration matching ILCD AreaOfProtectionValues.</rdfs:comment>
        <rdfs:label xml:lang="en">Area of Protection</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#BackgroundDatabase -->

    <owl:Class rdf:about="https://purl.org/eudpp#BackgroundDatabase">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Source"/>
        <rdfs:comment xml:lang="en">Source representing a background LCI database used for the LCA modelling (e.g. ecoinvent, GaBi/Sphera, Okobaudat).</rdfs:comment>
        <rdfs:label xml:lang="en">Background Database</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#ComplianceDeclaration -->

    <owl:Class rdf:about="https://purl.org/eudpp#ComplianceDeclaration">
        <rdfs:comment xml:lang="en">A statement that the LCA or EPD study complies with a given compliance system (typically ISO 14040/14044, ISO 14025, ISO 14067, ISO 21930, EN 15804+A2, or a PEFCR). Corresponds to ILCD+EPD element complianceDeclarations/compliance. The level of compliance (fully, partially, not compliant) is recorded via eudpp:complianceStatus.</rdfs:comment>
        <rdfs:label xml:lang="en">Compliance Declaration</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#ComplianceStatus -->

    <owl:Class rdf:about="https://purl.org/eudpp#ComplianceStatus">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://purl.org/eudpp#fullyCompliant"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#notCompliant"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#partiallyCompliant"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">Level of compliance declared by a ComplianceDeclaration relative to its compliance system. Enumeration of 3 named individuals (fullyCompliant, partiallyCompliant, notCompliant).</rdfs:comment>
        <rdfs:label xml:lang="en">Compliance Status</rdfs:label>
        <ilcdSource>LCA ontology extension</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#ComplianceSystem -->

    <owl:Class rdf:about="https://purl.org/eudpp#ComplianceSystem">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Source"/>
        <rdfs:comment xml:lang="en">A standard or programme against which an LCA or EPD study is declared compliant, such as ISO 14040/14044, ISO 14025, ISO 14067, ISO 21930, EN 15804+A2, PEFCR programmes, or a specific programme operator&apos;s scheme.</rdfs:comment>
        <rdfs:label xml:lang="en">Compliance System</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#EN15804ImpactIndicator -->

    <owl:Class rdf:about="https://purl.org/eudpp#EN15804ImpactIndicator">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#EN15804Indicator"/>
        <rdfs:comment xml:lang="en">An EN 15804+A2 characterised impact indicator (core set of 13 or the 6 additional &quot;with caveats&quot; indicators). Characterised via the EF 3.1 characterisation models. Results computed for this indicator are eudpp:LCIAResult instances.</rdfs:comment>
        <rdfs:label xml:lang="en">EN 15804 Impact Indicator</rdfs:label>
        <ilcdSource>ILCD+EPD extension</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#EN15804Indicator -->

    <owl:Class rdf:about="https://purl.org/eudpp#EN15804Indicator">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#LCIAIndicator"/>
        <rdfs:comment xml:lang="en">An indicator defined by EN 15804+A2 (core impact, impact with caveats, resource use, waste output, or output-flow indicator). Subclass of the abstract eudpp:LCIAIndicator parent. Named individuals of this class (and its subclasses) are used as the indicator that an eudpp:LCIAOrInventoryMethod calculates values for. Note: an EN15804Indicator individual is the indicator definition; a result computed for that indicator is an eudpp:LCAResult instance (LCIAResult or InventoryIndicatorResult sibling).</rdfs:comment>
        <rdfs:label xml:lang="en">EN 15804 Indicator</rdfs:label>
        <ilcdSource>ILCD+EPD extension</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#EN15804IndicatorGroup -->

    <owl:Class rdf:about="https://purl.org/eudpp#EN15804IndicatorGroup">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://purl.org/eudpp#group_coreImpact"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#group_exportedEnergy"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#group_resourceUse"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#group_valorisation"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#group_waste"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#group_withCaveats"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">Grouping of the EN 15804+A2 indicators as printed in the standard&apos;s tables: core impact (Table 3), impact indicators with caveats (Table 4), resource use (Table 5 resource use), waste categories (Table 5 waste), output flows valorisation (Table 5 output flows), exported energy (Table 5 output flows). Enumeration of 6 named individuals.</rdfs:comment>
        <rdfs:label xml:lang="en">EN 15804 Indicator Group</rdfs:label>
        <ilcdSource>LCA ontology extension</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#EN15804InventoryIndicator -->

    <owl:Class rdf:about="https://purl.org/eudpp#EN15804InventoryIndicator">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#EN15804Indicator"/>
        <rdfs:comment xml:lang="en">An EN 15804+A2 inventory-level indicator (resource use, waste disposed, or output flow for valorisation / exported energy). Not characterised; value is an aggregated inventory quantity. Results computed for this indicator are eudpp:InventoryIndicatorResult instances.</rdfs:comment>
        <rdfs:label xml:lang="en">EN 15804 Inventory Indicator</rdfs:label>
        <ilcdSource>ILCD+EPD extension</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#EPDDocument -->

    <owl:Class rdf:about="https://purl.org/eudpp#EPDDocument">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Source"/>
        <rdfs:comment xml:lang="en">Source representing the published PDF or HTML EPD document itself (as distinct from the ILCD+EPD machine-readable EPDStudy).</rdfs:comment>
        <rdfs:label xml:lang="en">EPD Document</rdfs:label>
        <ilcdSource>ILCD+EPD extension</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#EPDStudy -->

    <owl:Class rdf:about="https://purl.org/eudpp#EPDStudy">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#LCAStudy"/>
        <rdfs:comment xml:lang="en">An LCA study that conforms to EN 15804+A2 with EF 3.1 characterisation, i.e. an Environmental Product Declaration. Inherits all study-level metadata from eudpp:LCAStudy (compliance declarations, manufacturer records, reviews, LCA results, etc.) and adds EPD-specific properties: ILCD+EPD format version (eudpp:epdFormatVersion), registration number, expiry date, reference to the published EPD document (eudpp:EPDDocument via referenceToOriginalEPD), reference to the applicable Product Category Rules (eudpp:PCR via referenceToPCR). EN 15804+A2 module values per LCAResult are used to populate per-life-cycle-module values. Replaces v1.9.4&apos;s mixed structure and v1.9.5&apos;s eudpp:EPDDataSet.</rdfs:comment>
        <rdfs:label xml:lang="en">EPD Study</rdfs:label>
        <rdfs:label xml:lang="de">EPD-Studie</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://indatawg.github.io/ILCD-EPD-Data-Format/doc/"/>
        <ilcdSource>ILCD+EPD extension</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#EnvironmentalFootprintScore -->

    <owl:Class rdf:about="https://purl.org/eudpp#EnvironmentalFootprintScore">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#LCIAIndicator"/>
        <rdfs:comment xml:lang="en">An aggregated single-score indicator computed as the normalised and weighted sum of a set of impact-category results. Direct subclass of eudpp:LCIAIndicator (sibling of eudpp:EN15804Indicator and eudpp:LCIAImpactIndicator), distinct from those because the single score is a derived aggregate and not itself an impact category. Holds one named individual eudpp:ind_EF_singleScore representing the EU Environmental Footprint single score (PEF score). The applied normalisation factors and weighting set are not modelled here as properties; they are determined by the active EF / PEF methodology version, which is resolvable via the study&apos;s eudpp:hasComplianceDeclaration link to a eudpp:ComplianceSystem source. Results computed for an EnvironmentalFootprintScore individual are eudpp:LCIAResult instances. NEW class introduced in v1.9.7.</rdfs:comment>
        <rdfs:label xml:lang="en">Environmental Footprint Score</rdfs:label>
        <ilcdSource>LCA ontology extension</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#ImpactModel -->

    <owl:Class rdf:about="https://purl.org/eudpp#ImpactModel">
        <rdfs:comment xml:lang="en">The characterisation model underlying an LCIA method (e.g. IPCC AR6 2021 for GWP). Corresponds to ILCD+EPD element impactModel of an LCIA Method Data Set. Carries a model name (eudpp:modelName), optional version (eudpp:modelVersion), and optional bibliographic source (eudpp:referenceToModelSource).</rdfs:comment>
        <rdfs:label xml:lang="en">Impact Model</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#InventoryIndicatorResult -->

    <owl:Class rdf:about="https://purl.org/eudpp#InventoryIndicatorResult">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#LCAResult"/>
        <rdfs:comment xml:lang="en">Aggregated inventory-indicator result computed for an EN 15804+A2 inventory indicator (Table 5: resource use, waste categories, output flows). Sibling of eudpp:LCIAResult. Structurally identical to LCIAResult (per-module, per-scenario numerical values via eudpp:LCIAModuleValue). Important disambiguation: this class represents the AGGREGATED inventory-indicator value (e.g. total kg of HWD across A1-A3 for one product), as printed in EN 15804+A2 EPD tables and computed by an LCIAOrInventoryMethod instance. It is NOT the raw flow-level life-cycle inventory (LCI) result of a process (which would be a list of elementary-flow exchanges with amounts and units, and is out of scope for this DPP-oriented LCA module). Renamed in v1.9.7 from v1.9.6&apos;s eudpp:InventoryResult to make this distinction explicit. Distinguishing impact-result and inventory-indicator-result as siblings under a common eudpp:LCAResult parent reflects the conceptual distinction in EN 15804+A2 between Tables 3/4 (impact) and Table 5 (inventory) and supports separate downstream rendering in standard EPD tables.</rdfs:comment>
        <rdfs:label xml:lang="en">Inventory Indicator Result</rdfs:label>
        <ilcdSource>ILCD+EPD extension</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#LCAResult -->

    <owl:Class rdf:about="https://purl.org/eudpp#LCAResult">
        <rdfs:comment xml:lang="en">Abstract umbrella class for any LCA computation output of a study. Has two siblings as concrete subclasses: eudpp:LCIAResult (characterised impact result) and eudpp:InventoryIndicatorResult (aggregated inventory-indicator result). Both are produced from the same life-cycle inventory but via different calculation paths: LCIAResult applies characterisation factors of an LCIA method, InventoryIndicatorResult is a sum/aggregation over the inventory without characterisation. Both are computed by an eudpp:LCIAOrInventoryMethod (the unified method class). Connected to LCAStudy via eudpp:hasLCAResult; sub-properties eudpp:hasLCIAResult and eudpp:hasInventoryIndicatorResult narrow the result type.</rdfs:comment>
        <rdfs:label xml:lang="en">LCA Result</rdfs:label>
        <ilcdSource>LCA ontology extension</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#LCAStudy -->

    <owl:Class rdf:about="https://purl.org/eudpp#LCAStudy">
        <rdfs:comment xml:lang="en">A life-cycle assessment study of a product, conducted per ISO 14040/14044, producing one or more LCA results (eudpp:LCAResult, with subclasses eudpp:LCIAResult for characterised impact results and eudpp:InventoryIndicatorResult for aggregated inventory-indicator results). The general study container, applicable to any product whether or not the study follows EN 15804+A2. Construction-products EPDs use the subclass eudpp:EPDStudy. Carries study-level metadata (UUID, dataset version, name, reference year, license, copyright, ILCD format version, compliance declarations, manufacturer records, reviews, references to data sources / background databases / PEFCR, etc.). Cross-module link from a product to this class is provided by the Connector property eudpp:hasLCAStudy.</rdfs:comment>
        <rdfs:label xml:lang="en">LCA Study</rdfs:label>
        <ilcdSource>LCA ontology extension</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#LCIAImpactCategory -->

    <owl:Class rdf:about="https://purl.org/eudpp#LCIAImpactCategory">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://purl.org/eudpp#acidification"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#climateChange"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#eutrophication"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#freshwaterEcotoxicity"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#humanToxicity"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#ionisingRadiationEcosystems"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#ionisingRadiationHumanHealth"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#landUseSoilQuality"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#marineEcotoxicity"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#ozoneDepletion"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#photochemicalOzoneFormation"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#resourceUseFossil"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#resourceUseMineralsMetals"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#respiratoryInorganics"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#terrestrialEcotoxicity"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#waterUseDeprivation"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">A mid-point impact category that an LCIAMethod addresses. Enumeration matching ILCD LCIAImpactCategoryValues.</rdfs:comment>
        <rdfs:label xml:lang="en">LCIA Impact Category</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#LCIAImpactIndicator -->

    <owl:Class rdf:about="https://purl.org/eudpp#LCIAImpactIndicator">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#LCIAIndicator"/>
        <rdfs:comment xml:lang="en">A characterised impact indicator outside the EN 15804+A2 selection — direct subclass of eudpp:LCIAIndicator, sibling of eudpp:EN15804Indicator. Holds the 16 official EF 3.1 / PEF impact category indicators as named individuals (Andreasi Bassi et al., JRC, 2023). These are the impact indicators used by general LCA studies (eudpp:LCAStudy) following the EU Environmental Footprint method, distinct from the EN 15804+A2 set used by EPDStudy. The two sets overlap conceptually — both have e.g. a &quot;Climate change&quot; indicator with kg CO2-eq — but differ operationally: EN 15804+A2 splits Climate change into four sub-indicators (total, fossil, biogenic, luluc) and selects 6 &quot;with caveats&quot; indicators with EN-specific reporting rules; EF 3.1 keeps Climate change as one indicator and presents 16 categories at one aggregation level. An LCIAOrInventoryMethod can reference indicators from either set via eudpp:forIndicator. Results computed for an LCIAImpactIndicator are eudpp:LCIAResult instances. Results expressed in dimensionless / Pt for land use are recorded with their numerical value in eudpp:amount.</rdfs:comment>
        <rdfs:label xml:lang="en">LCIA Impact Indicator</rdfs:label>
        <ilcdSource>LCA ontology extension</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#LCIAIndicator -->

    <owl:Class rdf:about="https://purl.org/eudpp#LCIAIndicator">
        <rdfs:comment xml:lang="en">Abstract umbrella class for an indicator definition (impact or inventory category) that an eudpp:LCIAOrInventoryMethod calculates values for. Parent of eudpp:EN15804Indicator (which holds the EN 15804+A2 indicator definitions). For non-EN-15804 LCA studies (e.g. PEF, ISO 14067 carbon footprint), additional indicator individuals can be added as direct instances of LCIAIndicator or via further subclasses without modifying this ontology. Note: an indicator individual is the indicator DEFINITION (e.g. &quot;FW – Net use of fresh water, in m3&quot;); a numerical value computed for that indicator on a specific study is an eudpp:LCAResult instance (LCIAResult or InventoryIndicatorResult). NEW in v1.9.7.</rdfs:comment>
        <rdfs:label xml:lang="en">LCIA Indicator</rdfs:label>
        <ilcdSource>LCA ontology extension</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#LCIAMethodReport -->

    <owl:Class rdf:about="https://purl.org/eudpp#LCIAMethodReport">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Source"/>
        <rdfs:comment xml:lang="en">Source that documents a life-cycle impact assessment (LCIA) method (e.g. the EF 3.1 method description).</rdfs:comment>
        <rdfs:label xml:lang="en">LCIA Method Report</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#LCIAMethodology -->

    <owl:Class rdf:about="https://purl.org/eudpp#LCIAMethodology">
        <rdfs:comment xml:lang="en">A named, versioned LCIA methodology (a coherent set of LCIA methods sharing principles and a set of characterisation factors), to which one or more LCIAMethod instances belong. The enumeration below is seeded with six commonly-used methodologies in EPD practice and is intentionally NOT closed via owl:oneOf: new methodology individuals can be added by instantiating LCIAMethodology without modifying this ontology. Each individual SHOULD carry a skos:altLabel giving a short code (e.g. &quot;EF 3.1&quot;) and eudpp:methodologyVersion giving the version identifier.</rdfs:comment>
        <rdfs:label xml:lang="en">LCIA Methodology</rdfs:label>
        <ilcdSource>LCA ontology extension</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#LCIAModuleValue -->

    <owl:Class rdf:about="https://purl.org/eudpp#LCIAModuleValue">
        <rdfs:comment xml:lang="en">One numerical LCA-result value (impact or inventory-indicator) for a specific EN 15804+A2 life-cycle module (A1-A3, A4, ..., D) and optionally a specific scenario. Carries eudpp:amount (the numeric value), eudpp:forModule, optionally eudpp:forScenario, and eudpp:isDeclared (boolean: true if the module is declared with this value; false if the module is explicitly not declared for this indicator). Used by both eudpp:LCIAResult and eudpp:InventoryIndicatorResult instances. Corresponds to ILCD+EPD element epd:amount inside LCIAResult/other.</rdfs:comment>
        <rdfs:label xml:lang="en">LCIA Module Value</rdfs:label>
        <ilcdSource>ILCD+EPD extension</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#LCIAOrInventoryMethod -->

    <owl:Class rdf:about="https://purl.org/eudpp#LCIAOrInventoryMethod">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/eudpp#forIndicator"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A life-cycle method that produces values for one indicator from an inventory of elementary flows. Covers two cases: (a) characterised LCIA methods (which apply characterisation factors to compute a midpoint impact result), and (b) inventory aggregation methods (which sum / aggregate inventory flows to produce an inventory-indicator result, e.g. the EN 15804+A2 inventory indicators FW, HWD, PERE etc. defined as inventory-level by the standard&apos;s calculation rules). Corresponds to ILCD+EPD LCIA Method Data Set, which is used in practice for both kinds. Each instance identifies exactly one indicator (the ILCD+EPD pattern uses one LCIAMethodDataSet per indicator); this constraint is formalised as owl:maxCardinality 1 on eudpp:forIndicator. A methodology (in the ILCD sense of a set of methods sharing principles and characterisation factors) is represented by the object property eudpp:methodology, which can map a single method to one or several methodology individuals (1..n cardinality). ILCD+EPD LCIA Method Data Sets can also represent a methodology (a collection of methods); in that aggregator role, the LCIAOrInventoryMethod instance does not set forIndicator but uses eudpp:referenceToIncludedMethods to point to the per-indicator method instances. Renamed in v1.9.7 from v1.9.6&apos;s eudpp:LCIAMethod (the old name was misleading; in EPD/LCA software practice the same &quot;method&quot; object computes either characterised impacts or inventory aggregates).</rdfs:comment>
        <rdfs:label xml:lang="en">LCIA or Inventory Method</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://indatawg.github.io/ILCD-EPD-Data-Format/gitBranches/release/v1.3/schemadoc/ILCD_LCIAMethodDataSet.html"/>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#LCIAResult -->

    <owl:Class rdf:about="https://purl.org/eudpp#LCIAResult">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#LCAResult"/>
        <rdfs:comment xml:lang="en">Characterised life-cycle impact assessment result of applying one LCIAOrInventoryMethod to the inventory of an LCA or EPD study. Carries per-life-cycle-module and per-scenario numerical values (via eudpp:LCIAModuleValue). Sibling of eudpp:InventoryIndicatorResult. Corresponds to ILCD+EPD element LCIAResults/LCIAResult when the indicator is a characterised impact indicator.</rdfs:comment>
        <rdfs:label xml:lang="en">LCIA Result</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#LicenseType -->

    <owl:Class rdf:about="https://purl.org/eudpp#LicenseType">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://purl.org/eudpp#freeOfChargeAll"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#freeOfChargeMembers"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#freeOfChargeSome"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#licenseFee"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#licenseOther"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">License applicable to access and use of the LCA / EPD study. Enumeration matching ILCD LicenseTypeValues.</rdfs:comment>
        <rdfs:label xml:lang="en">License Type</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#LifeCycleModule -->

    <owl:Class rdf:about="https://purl.org/eudpp#LifeCycleModule">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://purl.org/eudpp#moduleA1"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#moduleA1A3"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#moduleA2"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#moduleA3"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#moduleA4"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#moduleA5"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#moduleB1"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#moduleB2"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#moduleB3"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#moduleB4"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#moduleB5"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#moduleB6"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#moduleB7"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#moduleC1"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#moduleC2"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#moduleC3"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#moduleC4"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#moduleD"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">A modelled life-cycle module per EN 15804+A2 (product stage A1-A3, construction A4-A5, use stage B1-B7, end-of-life C1-C4, benefits/loads D). Enumeration of 18 named individuals. Note that moduleA1A3 (aggregated product stage) is an alternative reporting form of A1+A2+A3; an EPD that reports A1-A3 should not additionally report A1, A2, A3 separately for the same indicator/scenario.</rdfs:comment>
        <rdfs:label xml:lang="en">Life Cycle Module</rdfs:label>
        <ilcdSource>ILCD+EPD extension</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#ManufacturerRecord -->

    <owl:Class rdf:about="https://purl.org/eudpp#ManufacturerRecord">
        <rdfs:comment xml:lang="en">A container that pairs one manufacturing Actor (via the Connector property identifiesManufacturer) with one or more manufacturing Facilities (via the Connector property hasManufacturingSite) for the product covered by an LCAStudy or its EPDStudy subclass. Corresponds to ILCD+EPD element epd24:manufacturer inside epd24:manufacturers. The ACTOR module does not model an actor-facility relationship natively, so this wrapper class is retained.</rdfs:comment>
        <rdfs:label xml:lang="en">Manufacturer Record</rdfs:label>
        <ilcdSource>ILCD+EPD extension</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#PCR -->

    <owl:Class rdf:about="https://purl.org/eudpp#PCR">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Source"/>
        <rdfs:comment xml:lang="en">Source that is a Product Category Rules document (EN 15804+A2 Table 2 Line 1). Used in EN 15804+A2 EPDStudy via eudpp:referenceToPCR.</rdfs:comment>
        <rdfs:label xml:lang="en">Product Category Rules (PCR)</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#PEFCR -->

    <owl:Class rdf:about="https://purl.org/eudpp#PEFCR">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Source"/>
        <rdfs:comment xml:lang="en">Source that is a Product Environmental Footprint Category Rules document, the European Commission Environmental Footprint methodology&apos;s product-category-specific rules. Parallel role to PCR but for PEF studies (rather than EN 15804+A2 EPD studies). Used by an LCAStudy via eudpp:referenceToPEFCR. NEW in v1.9.7.</rdfs:comment>
        <rdfs:label xml:lang="en">Product Environmental Footprint Category Rules (PEFCR)</rdfs:label>
        <ilcdSource>LCA ontology extension</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#Review -->

    <owl:Class rdf:about="https://purl.org/eudpp#Review">
        <rdfs:comment xml:lang="en">A verification / critical review performed on an LCA study or EPD study. Corresponds to ILCD+EPD element validation/review.</rdfs:comment>
        <rdfs:label xml:lang="en">Review</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://indatawg.github.io/ILCD-EPD-Data-Format/doc/"/>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#ReviewReport -->

    <owl:Class rdf:about="https://purl.org/eudpp#ReviewReport">
        <rdfs:subClassOf rdf:resource="https://purl.org/eudpp#Source"/>
        <rdfs:comment xml:lang="en">Source holding the complete critical-review / verification report referenced from a Review.</rdfs:comment>
        <rdfs:label xml:lang="en">Review Report</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#Source -->

    <owl:Class rdf:about="https://purl.org/eudpp#Source">
        <rdfs:comment xml:lang="en">A bibliographic or documentary source referenced from an LCA study, EPD study or LCIA Method. Abstract superclass; concrete source instances typically use one of the more specific subclasses (PCR, LCIAMethodReport, BackgroundDatabase, ComplianceSystem, ReviewReport, EPDDocument). Corresponds to ILCD+EPD Source Data Set.</rdfs:comment>
        <rdfs:label xml:lang="en">Source</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:Class>
    


    <!-- https://purl.org/eudpp#TypeOfReview -->

    <owl:Class rdf:about="https://purl.org/eudpp#TypeOfReview">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://purl.org/eudpp#accreditedThirdPartyReview"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#dependentInternalReview"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#independentExternalReview"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#independentInternalReview"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#independentReviewPanel"/>
                    <rdf:Description rdf:about="https://purl.org/eudpp#notReviewed"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">Kind of critical-review/verification performed on a dataset. Enumeration matching ILCD TypeOfReviewValues.</rdfs:comment>
        <rdfs:label xml:lang="en">Type of Review</rdfs:label>
        <ilcdSource>ILCD base</ilcdSource>
    </owl:Class>
    


