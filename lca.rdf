<?xml version="1.0"?>
<rdf:RDF xmlns="https://purl.org/eudpp/"
     xml:base="https://purl.org/eudpp/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:ns0="http:/purl.org/vocab/vann/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:qudt="http://qudt.org/schema/qudt#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:eudpp="https://purl.org/eudpp#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:dcterms1="http://purl.org/dc/dcterms/">
    <owl:Ontology rdf:about="https://purl.org/eudpp/LCA">
        <dcterms:bibliographicCitation rdf:resource="https://zenodo.org/records/15270342"/>
        <dcterms:created>2026-04-03</dcterms:created>
        <dcterms:creator>Fatima Danash</dcterms:creator>
        <dcterms:description>The LCA module provides classes and properties for representing life-cycle-assessment related information of the digital passport data of some product. 

DEPENDENCIES: This module has dependencies to the product EU DPP Core Ontology modules: P_DPP.</dcterms:description>
        <dcterms:issued>2026-04-30</dcterms:issued>
        <dcterms:license rdf:resource="https://www.apache.org/licenses/LICENSE-2.0"/>
        <dcterms:license>This ontology is licensed under the Apache License, Version 2.0. 
In case of dispute over Apache 2.0 applicability, or in case considering the ontology as a document, this ontology document is to be considered licensed under the Creative Commons Attribution 4.0 International (CC BY 4.0).</dcterms:license>
        <dcterms:title>The LCA module of the EU regulatory compliant Digital Product Passport (EU DPP LCA)</dcterms:title>
        <vann:preferredNamespacePrefix>lca</vann:preferredNamespacePrefix>
        <rdfs:comment>The LCA module of an EU DPP core ontology proposed by the CIRPASS-2 European project.</rdfs:comment>
        <rdfs:label>EU DPP LCA</rdfs:label>
        <owl:versionInfo>1.9.4</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/dcterms/bibliographicCitation -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/dcterms/bibliographicCitation"/>
    


    <!-- http://purl.org/dc/dcterms/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/dcterms/creator"/>
    


